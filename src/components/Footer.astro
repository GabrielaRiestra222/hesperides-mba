<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+HK:wght@100;300;400&display=swap');

  .footer {
    width: 100%;
    background: #0e0e0e;
    padding: 56px 0;
  }

  /* ── Sistema global de márgenes (igual que Stats/.section-inner) ── */
  .footer-inner {
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
    padding: 0 clamp(24px, 16.67vw, 320px);
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    row-gap: 20px;
    column-gap: clamp(20px, 2.5vw, 48px);
    align-items: center;
  }

  /* ── Logo — columna 1, fila 1+2, centrado verticalmente ── */
  .footer-logo {
    grid-column: 1;
    grid-row: 1 / 3;
    align-self: center;
  }

  .footer-logo img {
    height: 56px;
    width: auto;
    display: block;
  }

  /* ── RRSS — columna 3, fila 1 ── */
  .footer-rrss {
    grid-column: 3;
    grid-row: 1;
    display: flex;
    align-items: center;
    gap: 24px;
    justify-content: flex-end;
  }

  .footer-rrss a {
    display: flex;
    align-items: center;
    opacity: 0.85;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .footer-rrss a:hover {
    opacity: 1;
  }

  /* ── Links legales — fila 2, desde col 2 hasta el margen derecho ── */
  .footer-links {
    grid-column: 2 / 4;
    grid-row: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-links a {
    font-family: "Noto Sans HK", "Noto Sans", sans-serif;
    font-weight: 300;
    font-size: 15px;
    line-height: 38px;
    letter-spacing: 0.02em;
    color: #ffffff;
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .footer-links a:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      row-gap: 24px;
      padding: 0 0px;
      justify-items: center;
    }

    .footer-logo {
      grid-column: 1;
      grid-row: 1;
      align-self: auto;
      
    }


    .footer-rrss {
      grid-column: 1;
      grid-row: 2;
      justify-content: center;
    }

    .footer-links {
      grid-column: 1;
      grid-row: 3;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    .footer-links a {
      line-height: 32px;
      text-align: center;
    }
  }
  @media (min-width: 901px) {
    .footer-inner { padding-left: calc(clamp(20px, 16.67vw, 320px) + clamp(32px, 5vw, 80px)); padding-right: calc(clamp(20px, 16.67vw, 320px) + clamp(32px, 5vw, 80px)); max-width: none; }
  }
  .footer-links {
     
      gap: 4px;
    }

    .footer-links a {
      line-height: 32px;
      font-size: 10px;
      text-align: center;
    }
</style>