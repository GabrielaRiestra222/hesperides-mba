---
// Header.astro
---

<header class="site-header">
  <div class="header-inner">

    <!-- Logo + badge online -->
    <div class="logo-wrap">
      <img
        src="./img/Logo.h_horz_black.png"
        alt="Universidad de las Hespérides"
        class="logo-img"
      />
      <span class="online-badge">online</span>
    </div>

    <!-- Navegación -->
    <nav class="main-nav">
      <a href="#">La Universidad</a>
      <a href="#">Estudios</a>
      <a href="#">Noticias y Eventos</a>
      <a href="#">Admisiones</a>
    </nav>

  </div>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+HK:wght@300;400;500;700&display=swap');

  .site-header {
    width: 100%;
    background: #FFCD00;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1920px;
    margin: 0 auto;
    padding: 0 clamp(40px, 6vw, 120px);
    height: clamp(80px, 7.8vw, 150px);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── Logo wrap: imagen + badge en fila, alineados al centro vertical ── */
  .logo-wrap {
    display: flex;
    flex-direction: row;
    align-items: flex-end; /* badge alineado al borde inferior del logo */
    gap: 8px;
    margin-left: 6px;
  }

  .logo-img {
    width: 205px;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* caja negra "online" pegada a la derecha del logo, alineada abajo */
  .online-badge {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.02em;
    color: #fff;
    background: #1a1a1a;
    padding: 4px 8px 5px;
    white-space: nowrap;
    /* bajar un poco para que coincida con la línea base del texto inferior del logo */
    margin-bottom: 2px;
  }

  /* ── Nav ── */
  .main-nav {
    display: flex;
    align-items: center;
    gap: clamp(20px, 2.65vw, 51px);
  }

  .main-nav a {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: 15px;
    line-height: 100%;
    letter-spacing: 0;
    color: #1a1a1a;
    text-decoration: none;
    white-space: nowrap;
    position: relative;
  }

  .main-nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: #1a1a1a;
    transition: width 0.25s ease;
  }

  .main-nav a:hover::after,
  .main-nav a.active::after {
    width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .main-nav { display: none; }
    .header-inner { padding: 0 24px; }
  }
</style>