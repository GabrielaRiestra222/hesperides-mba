---
/**
 * Render básico de richText (Lexical / Payload).
 * Cubre: heading, paragraph, linebreak, bold/italic/underline, link.
 */

const { content } = Astro.props;

function escapeHtml(str = '') {
  return str
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}

// Lexical usa "format" como bitmask. Valores comunes:
const FORMAT_BOLD = 1;
const FORMAT_ITALIC = 2;
const FORMAT_UNDERLINE = 8;

function wrapInline(text, format = 0) {
  let out = escapeHtml(text);

  if (format & FORMAT_UNDERLINE) out = `<u>${out}</u>`;
  if (format & FORMAT_ITALIC) out = `<em>${out}</em>`;
  if (format & FORMAT_BOLD) out = `<strong>${out}</strong>`;

  return out;
}

function renderNode(node) {
  if (!node) return '';

  switch (node.type) {
    case 'text':
      return wrapInline(node.text ?? '', node.format ?? 0);

    case 'linebreak':
      return '<br />';

    case 'link': {
      const href = node.url || '#';
      const inner = (node.children || []).map(renderNode).join('');
      return `<a href="${escapeHtml(href)}">${inner}</a>`;
    }

    case 'heading': {
      const tag = node.tag || 'h2';
      const inner = (node.children || []).map(renderNode).join('');
      return `<${tag}>${inner}</${tag}>`;
    }

    case 'paragraph': {
      const inner = (node.children || []).map(renderNode).join('');
      // Si el párrafo está vacío, no lo pintamos
      if (!inner.trim()) return '';
      return `<p>${inner}</p>`;
    }

    default: {
      // fallback: intenta renderizar sus hijos
      const inner = (node.children || []).map(renderNode).join('');
      return inner;
    }
  }
}

const html =
  content?.root?.children
    ? content.root.children.map(renderNode).join('')
    : '';
---

<div class="richtext" set:html={html} />
