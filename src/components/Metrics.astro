

<section class="py-32 lg:py-48 bg-foreground text-background">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-16">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-16 lg:gap-20">
      {items.map((metric) => (
        <div class="space-y-4">
          <div class="font-serif text-6xl lg:text-7xl">
            {metric.value}
          </div>
          <div class="text-sm tracking-widest uppercase text-muted-foreground">
            {metric.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
