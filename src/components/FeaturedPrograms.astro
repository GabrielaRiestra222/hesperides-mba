---
const res = await fetch(
  "http://localhost:3000/api/programs?where[featured][equals]=true&sort=order"
);
const data = await res.json();
const programs = data.docs;
---

<section class="py-32 lg:py-48">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-16">

    <!-- Section header -->
    <div class="mb-24 lg:mb-32 max-w-3xl">
      <h2 class="text-5xl lg:text-6xl mb-8 leading-tight serif">
        Programas destacados
      </h2>
      <p class="text-xl text-gray-500 leading-relaxed">
        Contenidos rigurosos pensados para quienes valoran el conocimiento profundo y la reflexión crítica.
      </p>
    </div>

    <!-- Programs -->
    <div class="space-y-24 lg:space-y-32">
      {programs.map((program, index) => (
        <div
          class={`grid lg:grid-cols-12 gap-12 lg:gap-16 items-start ${
            index % 2 === 1 ? "lg:flex-row-reverse" : ""
          }`}
        >
          <!-- Image -->
          <div class={`lg:col-span-7 ${index % 2 === 1 ? "lg:col-start-6" : ""}`}>
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={`http://localhost:3000${program.image.sizes.large.url}`}
                alt={program.title}
                class="w-full h-full object-cover grayscale"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Content -->
          <div
            class={`lg:col-span-5 space-y-6 lg:pt-8 ${
              index % 2 === 1 ? "lg:col-start-1 lg:row-start-1" : ""
            }`}
          >
            <div class="space-y-4">
              <div class="text-xs tracking-widest uppercase text-gray-400">
                {program.duration} · {program.level}
              </div>

              <h3 class="text-4xl lg:text-5xl serif">
                {program.title}
              </h3>

              <p class="text-lg text-gray-600 leading-relaxed">
                {program.description}
              </p>
            </div>

            <div class="pt-4">
              <a
                href={`/programas/${program.slug}`}
                class="text-sm tracking-wide underline underline-offset-4 hover:opacity-50 transition-opacity"
              >
                Ver programa →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.serif {
  font-family: var(--font-serif);
  font-weight: 400;
}
</style>
