<section class="profesores-section">
  <!-- Usa el sistema global de márgenes -->
  <div class="profesores-inner">

    <!-- Título: medium (500) + bold en "hoy" -->
    <h2 class="profesores-titulo">
      Aprende con quienes están dirigiendo empresas <strong>hoy</strong>
    </h2>

    <!-- Carrusel: flechas fuera mediante position absolute -->
    <div class="profesores-carousel-shell">

      <!-- Flecha izquierda — sale fuera del inner -->
      <button class="prof-arrow prof-arrow--prev" id="prof-prev" aria-label="Anterior" disabled>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="profesores-overflow" id="profesores-overflow">
        <div class="profesores-track" id="profesores-track">
          {profesores.map((p) => (
            <div class="prof-card"
              data-nombre={p.nombre} data-cargo={p.cargo}
              data-bio={p.bio} data-foto-compact={p.fotoCompact} data-foto-expanded={p.fotoExpanded}
              role="button" tabindex="0" aria-label={`Ver perfil de ${p.nombre}`}>

              <!-- Vista compacta -->
              <div class="prof-card-compact">
                <img src={p.fotoCompact} alt={p.nombre} class="prof-foto" loading="lazy" />
                <div class="prof-info">
                  <p class="prof-nombre">{p.nombre}</p>
                  <p class="prof-cargo">{p.cargo}</p>
                </div>
              </div>

              <!-- Vista expandida -->
              <div class="prof-card-expanded">
                <div class="prof-exp-foto-col">
                  <img src={p.fotoExpanded} alt={p.nombre} class="prof-exp-foto" loading="lazy" />
                </div>
                <div class="prof-exp-body">
                  <button class="prof-exp-close" aria-label="Cerrar">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                      <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                  </button>
                  <p class="pexp-nombre">{p.nombre}</p>
                  <span class="pexp-tag">{p.cargo}</span>
                  <p class="pexp-bio">{p.bio}</p>
                </div>
              </div>

            </div>
          ))}
        </div>
      </div>

      <!-- Flecha derecha — sale fuera del inner -->
      <button class="prof-arrow prof-arrow--next" id="prof-next" aria-label="Siguiente">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    <!-- Botón -->
    <div class="profesores-boton-wrap">
      <a href="#folleto" class="profesores-boton">QUIERO DESCARGAR FOLLETO</a>
    </div>

  </div>
</section>

<style>
  /* ══ Sección ══ */
  .profesores-section {
    width: 100%;
    background: #FFCD00;
    padding-top: clamp(48px, 5vw, 80px);
    padding-bottom: clamp(48px, 5vw, 80px);
  }

  /* ── Inner ── */
  .profesores-inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 16.67vw, 320px);
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 3vw, 44px);
  }

  @media (max-width: 900px) {
    .profesores-inner { padding: 0 20px; }
  }

  /* ══ Título: font-weight 500 (medium), "hoy" en 700 ══ */
  .profesores-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(22px, 2.08vw, 40px);
    line-height: 1.2;
    color: #1a1a1a;
    margin: 0;
  }
  .profesores-titulo strong {
    font-weight: 700;
  }

  /* ══ Shell del carrusel: position relative para flechas absolute ══ */
  .profesores-carousel-shell {
    position: relative;
    overflow: visible;
  }

  /* ══ Flechas: sencillas, position absolute fuera del inner ══ */
  .prof-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,0.4);
    background: transparent;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }
  .prof-arrow:hover { background: #1a1a1a; color: #FFCD00; border-color: #1a1a1a; }
  .prof-arrow:disabled { opacity: 0.25; cursor: default; }

  /* Salen fuera del inner */
  .prof-arrow--prev { left: -48px; }
  .prof-arrow--next { right: -48px; }

  /* ══ Overflow y track ══ */
  .profesores-overflow {
    overflow: hidden;
    width: 100%;
  }
  /* Cuando hay activa, permitir que la card crezca pero el track sigue clipado */
  .profesores-overflow.has-active { overflow: hidden; }

  .profesores-track {
    display: flex;
    gap: 20px;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
    align-items: flex-start;
  }

  /* ══ Card compacta — más estrecha, gap mayor ══ */
  .prof-card {
    position: relative;
    flex-shrink: 0;
    width: 222px;   /* JS sobreescribe */
    height: 400px;
    border-radius: 20px;
    background: #fff;
    box-shadow: 0 3px 12px rgba(0,0,0,0.12);
    cursor: pointer;
    transition: width 0.45s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s;
    overflow: hidden;
  }
  .prof-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.18); }

  /* Activa: JS calcula compactW*2 + GAP para ocupar exactamente 2 slots */
  .prof-card.active {
    cursor: default;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    z-index: 10;
  }

  /* Vista compacta */
  .prof-card-compact {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    transition: opacity 0.25s ease;
  }
  .prof-card.active .prof-card-compact { opacity: 0; pointer-events: none; }

  .prof-foto {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .prof-info {
    position: absolute;
    bottom: 14px; left: 14px; right: 14px;
    z-index: 2;
    margin-left: 7px;
  }
  .prof-nombre {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 39px;
    color: #fff;
    margin: 0 0 2px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }
  .prof-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: 14px;
    line-height: 15px;
    color: rgba(255,255,255,0.85);
    margin: 0;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Vista expandida */
  .prof-card-expanded {
    position: absolute;
    inset: 0;
    display: flex;
    overflow: hidden;
    background: #fff;
    border-radius: inherit;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease 0.2s;
  }
  .prof-card.active .prof-card-expanded {
    opacity: 1;
    pointer-events: auto;
  }

  .prof-exp-foto-col {
    width: 180px;
    flex-shrink: 0;
    align-self: stretch;
    border-radius: 24px 0 0 24px;
    overflow: hidden;
  }
  .prof-exp-foto {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .prof-exp-body {
    flex: 1;
    padding: 18px 18px 18px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.1) transparent;
    position: relative;
  }
  .prof-exp-body::-webkit-scrollbar { width: 3px; }
  .prof-exp-body::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 3px; }

  .pexp-nombre {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: 28px;
    line-height: 1.2;
    color: #000;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-right: 32px; /* espacio para el botón cerrar */
  }
  .pexp-tag {
    display: inline-block;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: 10px;
    line-height: 1.35;
    color: #fff;
    background: #1a1a1a;
    padding: 4px 12px;
    border-radius: 20px;
    width: fit-content;
  }
  .pexp-bio {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    color: #000000;
    margin: 0;
  }

  /* Botón cerrar */
  .prof-exp-close {
    position: absolute;
    top: 14px; right: 14px;
    width: 26px; height: 26px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,0.15);
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.18s;
    z-index: 5;
    color: #000;
  }
  .prof-exp-close:hover { background: #f0f0f0; }

  /* ══ Botón sección ══ */
  .profesores-boton-wrap {
    display: flex;
    justify-content: flex-end;
  }
  .profesores-boton {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 28px;
    border-radius: 999px;
    background: #1a1a1a;
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s;
  }
  .profesores-boton:hover { background: #fff; color: #1a1a1a; }

  /* ══ Mobile ══ */
  @media (max-width: 860px) {
    .prof-arrow--prev,
    .prof-arrow--next { display: none; }

    .profesores-titulo { font-size: 28px; line-height: 1.25; }

    .prof-card { height: 380px; }
    .prof-nombre { font-size: 14px; }
    .prof-cargo  { font-size: 10px; }

    .prof-card.active {
      width: calc(80vw) !important;
      height: 380px !important;
    }

    .prof-card-expanded { flex-direction: column; }
    .prof-exp-foto-col {
      width: 100%;
      height: 180px;
      border-radius: 24px 24px 0 0;
      align-self: auto;
      flex-shrink: 0;
    }
    .prof-exp-body { padding: 14px 16px 18px; }

    .profesores-boton-wrap { justify-content: center; }

    /* Flechas mobile inyectadas por JS */
    .prof-arrows-mobile {
      display: flex;
      gap: 48px;
      justify-content: center;
      width: 100%;
      margin-bottom: 16px;
    }
    /* En mobile las flechas son estáticas (no absolute) */
    .prof-arrows-mobile .prof-arrow {
      position: static;
      transform: none;
    }
  }
</style>

<script>
  const track    = document.getElementById('profesores-track') as HTMLElement;
  const overflow = document.getElementById('profesores-overflow') as HTMLElement;
  const prevBtn  = document.getElementById('prof-prev') as HTMLButtonElement;
  const nextBtn  = document.getElementById('prof-next') as HTMLButtonElement;
  const cards    = Array.from(document.querySelectorAll<HTMLElement>('.prof-card'));
  const GAP      = 20;
  let current    = 0;
  let compactW   = 140;

  function vis() {
    const w = window.innerWidth;
    return w >= 1200 ? 5 : w >= 900 ? 4 : w >= 650 ? 3 : 1;
  }

  function expandedW() {
    return compactW * 2 + GAP;
  }

  function setWidths() {
    const outer = (track.parentElement as HTMLElement).offsetWidth;
    const v = vis();
    const w = window.innerWidth;
    if (w < 650) {
      compactW = Math.floor(w * 0.72);
    } else {
      compactW = Math.floor((outer - GAP * (v - 1)) / v);
    }
    cards.forEach(c => {
      if (!c.classList.contains('active')) {
        c.style.width = compactW + 'px';
      }
    });
  }

  function cardStep() { return compactW + GAP; }
  function maxI() { return Math.max(0, cards.length - vis()); }

  function goTo(i: number) {
    current = Math.max(0, Math.min(i, maxI()));
    track.style.transform = `translateX(-${current * cardStep()}px)`;
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current >= maxI();
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));

  /* Expand / collapse */
  function closeActive() {
    const active = document.querySelector<HTMLElement>('.prof-card.active');
    if (active) {
      active.classList.remove('active');
      active.style.width = compactW + 'px';
      overflow.classList.remove('has-active');
    }
  }

  cards.forEach(card => {
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.prof-exp-close')) return;
      if (card.classList.contains('active')) return;
      closeActive();
      card.classList.add('active');
      card.style.width = window.innerWidth > 860 ? expandedW() + 'px' : `${Math.floor(window.innerWidth * 0.8)}px`;
      overflow.classList.add('has-active');
      setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' }), 50);
    });

    card.querySelector('.prof-exp-close')?.addEventListener('click', (e) => {
      e.stopPropagation();
      closeActive();
      setWidths();
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.prof-card')) closeActive();
  });

  // Touch swipe
  let tx = 0;
  track.addEventListener('touchstart', e => { tx = e.changedTouches[0].screenX; }, { passive: true });
  track.addEventListener('touchend', e => {
    const diff = tx - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
  }, { passive: true });

  window.addEventListener('resize', () => {
    closeActive();
    setWidths();
    goTo(Math.min(current, maxI()));
  });

  setWidths();
  goTo(0);
</script>