const profesores = [
  { id: "juan-carlos-andreu",  nombre: "Juan Carlos Andreu",       cargo: "Associate Director en World Health Management (WHM) Hospitals",              fotoCompact: "/img/Juan_Carlos_Andreu_duo.jpg", fotoExpanded: "/img/Juan_Carlos_Andreu_color.jpg",           bio: "Abogado, Economista, MBA, profesor en cursos de posgrado y Máster desde 1990, y ponente en cursos, seminarios y conferencias, en Europa, África e Iberoamérica. Empresario desde 1988, habiendo finalizado proyectos en 34 países de 4 continentes, fundamentalmente para el sector privado y en modelos PPP-CPP de colaboración Público Privada en salud. Director del MBA de Hespérides, y profesor de estrategia, emprendimiento e internacionalización. Miembro del Instituto Juan de Mariana, entre otras instituciones." },
  { id: "enrique-briega",      nombre: "Enrique Briega",           cargo: "Knowledge Expert Financial Services Practice en McKinsey & Company",         fotoCompact: "/img/enrique_briega_color_copy_2.jpg", fotoExpanded: "/img/enrique_briega_color.jpg",          bio: "Licenciado en Administración y Dirección de Empresas por la Universidad de Navarra, Máster en Finanzas Corporativas por SDA Bocconi y MBA por IESE Business School, con intercambio en Chicago Booth. Obtuvo la certificación Chartered Financial Analyst (CFA) en 2017. Ha trabajado en banca de inversión en BBVA y en consultoría estratégica en Europa, Oriente Medio y África, además de realizar voluntariado como consultor financiero en Centroamérica, África y Asia. Actualmente lidera el área de Research del sector bancario en McKinsey & Company para España y Portugal. Es miembro del Consejo de CFA Society Spain. En 2024 fue reconocido con el Global Emerging CFA Society Leader Award por CFA Institute." },
  { id: "gustavo-martinez",    nombre: "Gustavo Martinez",         cargo: "Divulgador financiero, gestor patrimonial y formador en Bolsa y mercados financieros", fotoCompact: "/img/Gustavo_Martinez_duo.jpg", fotoExpanded: "/img/Gustavo_Martinez_color.jpg",    bio: "Gestor patrimonial y directivo en XTB. Profesor en la Universidad Francisco Marroquín, con formación en múltiples grados y másteres de prestigio, como el Máster en Value Investing y Teoría del Ciclo por OMMA y el Máster en Bolsa por el IEB." },
  { id: "juan-ramon-rallo",    nombre: "Juan Ramón Rallo",         cargo: "Decano de la Escuela de Grado de la Universidad de las Hespérides",          fotoCompact: "/img/Juan_Ramón_Rallo_copia_duo.jpg", fotoExpanded: "/img/Juan_Ramón_Rallo_copia.png",          bio: "Doctor en Economía por la Universidad Rey Juan Carlos y licenciado en Derecho por la Universidad de Valencia. Fundador, decano y director del Grado y Máster en Economía de la Universidad de las Hespérides, además de profesor en diversas instituciones educativas. Colabora como analista económico en EsRadio y El Confidencial, y es autor de numerosos libros, entre ellos Anti-Marx, Liberalismo y Una revolución liberal para España." },
  { id: "luca-delloro",        nombre: "Luca Dell'Oro",            cargo: "Fundador y CEO de The Baker Studio",                                          fotoCompact: "/img/Luca_Dell'Oro_duo.jpg", fotoExpanded: "/img/Luca_Dell'Oro_color.jpg",                 bio: "Acumula más de 30 años de experiencia en negocios y marketing, la mitad de ellos en multinacionales de siete países diferentes. Desde hace más de dos décadas compagina su actividad profesional con la docencia universitaria y de posgrado en escuelas de negocios españolas. Destaca por su pasión por el emprendimiento, la gestión del valor y su enfoque directo y transparente en las relaciones personales y profesionales." },
  { id: "carmen-dominguez",    nombre: "Carmen Domínguez Domech",  cargo: "Global Finance, Control y Development Planning Director en Iberdrola",       fotoCompact: "/img/Carmen_Domínguez_Domech_duo.jpg", fotoExpanded: "/img/Carmen_Domínguez_Domech_coloe.jpg",  bio: "Doctora en Ciencias Económicas y Empresariales, Certified International Investment Analyst (CIIA) y experta en buen gobierno corporativo. Con amplia trayectoria en el sector privado como directiva en Finanzas, fue premiada como Corporate Finance Leader Europea 2023 por NXT Generation y por sus investigaciones sobre la crisis financiera internacional." },
  { id: "jose-ruiz-de-alda",   nombre: "José Ruiz de Alda",        cargo: "Asesor de CORE VALUE FIL",                                                    fotoCompact: "/img/José_Ruiz_de_Alda_duo.jpg", fotoExpanded: "/img/José_Ruiz_de_Alda_color.jpg",             bio: "Licenciado en Administración y Dirección de Empresas por la Universidad de Deusto, complementa su formación con másteres en Finanzas y Contabilidad y en Bolsa y Mercados Financieros. Su conocimiento del Value Investing se refleja en su papel como consejero en CIMA Global Value SICAV y su labor docente en OMMA Business School y el Instituto de Estudios Bursátiles." },
  { id: "eric-risco",          nombre: "Eric Risco",               cargo: "AI Tech Lead en Andorra Telecom y Speaker TEDx",                              fotoCompact: "/img/Eric_Risco_duo.jpg", fotoExpanded: "/img/Eric_Risco_color.jpg",                           bio: "Ingeniero de software y profesor con una visión clara: utilizar la tecnología para la eficiencia operativa. Actualmente ejerce como Ingeniero de Inteligencia Artificial en Andorra Telecom, liderando la adopción tecnológica en grandes infraestructuras. Divulgador en plataformas como TEDx, donde desmitifica la IA para centrarse en la utilidad real de resolver problemas cotidianos y empresariales, alejándose del \"hype\" y centrándose en la estadística aplicada." },
  { id: "ignacio-santaballa",  nombre: "Ignacio Santaballa",       cargo: "Country Sales Manager en Securitas Direct",                                  fotoCompact: "/img/Ignacio_Santaballa_duo.jpg", fotoExpanded: "/img/Ignacio_Santaballa_color.jpg",           bio: "Nacho Santaballa es Country Sales Manager en Securitas Direct, con más de una década de experiencia liderando equipos comerciales y estrategias de marketing orientadas al cliente. Especializado en crecimiento, fidelización y gestión de operaciones, combina una sólida trayectoria en ventas con formación en marketing y dirección de empresas." },
  { id: "eduardo-fernandez",   nombre: "Eduardo Fernández Luiña",  cargo: "Decano de la Escuela de Postgrado de la Universidad de las Hespérides",      fotoCompact: "/img/Eduardo_Fernández_Luiña_duo.jpg", fotoExpanded: "/img/Eduardo_Fernández_Luiña_color.jpg",  bio: "Doctor en Procesos Políticos y decano de la Escuela de Postgrado de la Universidad de las Hespérides. Su investigación se centra en el sistema político guatemalteco y la democracia." },
  { id: "mauricio-garita",     nombre: "Mauricio Garita",          cargo: "Fundador y financial director en Olive Tree Capital",                        fotoCompact: "/img/Mauricio_Garita_duo.jpg", fotoExpanded: "/img/Mauricio_Garita_color.jpg",                bio: "Asesor estratégico especializado en blockchain, coaching filosófico y crecimiento empresarial. Lidera las empresas Vivir Mejor, 5&2 y Olive Tree Capital. Doctor en Economía por la Universidad Pontificia de Salamanca y MSc en Blockchain y Moneda." },
  { id: "gonzalo-illesca",     nombre: "Gonzalo Illesca",          cargo: "Consultor externo en Likydo",                                                fotoCompact: "/img/Gonzalo_Illesca_duo.jpg", fotoExpanded: "/img/Gonzalo_Illesca_color.jpg",                bio: "Ingeniero Comercial y Licenciado en Ciencias de la Administración por la Universidad de la Frontera, dirige el Máster en Creación de Empresas e Innovación en la Universidad de las Hespérides. Su trayectoria incluye el diseño y liderazgo de programas de incubación e innovación para organizaciones de prestigio como Founder Institute, Demium Startups, Renfe, KPMG y Procter & Gamble. Como emprendedor, ha fundado proyectos innovadores en las industrias de videojuegos, joyería y software." },
  { id: "eva-lopez",           nombre: "Eva López González",       cargo: "Profesora",                                                                   fotoCompact: "/img/Eva_López_González_copia_duo.jpg", fotoExpanded: "/img/Eva_López_González_color.jpg",       bio: "Doctora en Ciencias Económicas, Empresariales y Jurídicas por la Universidad Politécnica de Cartagena. Su experiencia docente abarca asignaturas como Contabilidad Financiera, Contabilidad de Costes y Organización de los Recursos Humanos, complementada con su trayectoria profesional en contabilidad y asesoría fiscal. Ha publicado diversos trabajos científicos sobre Responsabilidad Social Corporativa, Earnings Management y Evasión Fiscal." },
  { id: "gonzalo-melian",      nombre: "Gonzalo Melián",           cargo: "Cofundador y vicerrector de la Universidad de las Hespérides",               fotoCompact: "/img/Gonzalo-Melian_duo.jpg", fotoExpanded: "/img/Gonzalo-Melian_color.jpg",                  bio: "Cofundador y vicerrector de la Universidad de las Hespérides (.h) y director y socio fundador de OMMA Business School Madrid. Miembro de la Mont Pelerin Society, del Instituto Juan de Mariana y de la Real Sociedad Económica de Amigos del País de Gran Canaria. Doctor en Economía (URJC) y Doctor en Arquitectura (ULPGC), ha sido F. A. Hayek Visiting Scholar en la George Mason University y Postdoctoral Visiting Researcher en la Cardiff University. Fue profesor adjunto en IE University (2007–2023) y director fundador de la sede en Madrid de la Universidad Francisco Marroquín. Ha publicado en revistas como Land Use Policy, European Planning Studies, Procesos de Mercado y Architecture, City and Environment." },
  { id: "florencia-roca",      nombre: "Florencia Roca",           cargo: "Directora de la Especialización en Finanzas de la Escuela de Negocios de la Universidad Francisco Marroquín", fotoCompact: "/img/Florencia-Rocaok_duo.jpg", fotoExpanded: "/img/Florencia-Rocaok.jpg",      bio: "Doctora en Finanzas por la Universidad del CEMA (Argentina) y directora del máster online en Administración de Empresas de la Universidad Francisco Marroquín. Destaca por sus publicaciones sobre evaluación de proyectos y finanzas para emprendedores, además de su labor como divulgadora a través del canal FEmprendedores en YouTube y redes sociales." },
  { id: "edgardo-spivak",      nombre: "Edgardo Javier Spivak",    cargo: "Director de Desarrollo y Comercial en The Lemon Tree Education",             fotoCompact: "/img/Edgardo_Javier_Spivak_duo.jpg", fotoExpanded: "/img/Edgardo_Javier_Spivak_color.jpg",      bio: "Doctor en Dirección Internacional de Empresas por la Universidad Nebrija, con Premio Extraordinario y tesis sobre redes sociales y comportamiento de compra. Especialista en marketing digital, estratégico y operativo, ha impartido clases en universidades de España, África e Iberoamérica. Es director comercial en The Lemon Tree Education y consultor con amplia trayectoria en proyectos internacionales." },
  { id: "miguel-angel-sanz",   nombre: "Miguel Ángel Sanz",        cargo: "Partner en Madavi",                                                           fotoCompact: "/img/Miguel-A-Sanz-300x300-1_duo.jpg", fotoExpanded: "/img/Miguel-A-Sanz-300x300-1.jpg",        bio: "Doctor Ingeniero Industrial por la Universidad de Oviedo, MBA por INSEAD y Master en Marketing Estratégico por ESADE. Está graduado en Teología por la Universidad de Deusto y diplomado en Teatro y Artes Escénicas por la Universidad del País Vasco. Es socio en Madavi, donde acompaña procesos de transformación empresarial y liderazgo. Ha sido profesor de programas ejecutivos y directivo en inversiones energéticas e infraestructuras." },
];
---

<section class="profesores-section" id="profesores">
  <!-- Usa el sistema global de márgenes -->
  <div class="profesores-inner">

    <!-- Título: medium (500) + bold en "hoy" -->
    <h2 class="profesores-titulo">
      Aprende con quienes están dirigiendo empresas <strong>hoy</strong>
    </h2>

    <!-- Carrusel: flechas fuera mediante position absolute -->
    <div class="profesores-carousel-shell">

      <!-- Flecha izquierda — sale fuera del inner -->
      <button class="prof-arrow prof-arrow--prev" id="prof-prev" aria-label="Anterior">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="profesores-overflow" id="profesores-overflow">
        <div class="profesores-track" id="profesores-track">
          {profesores.filter(p => !p.hidden).map((p) => (
            <div class="prof-card"
              data-nombre={p.nombre} data-cargo={p.cargo}
              data-bio={p.bio} data-foto-compact={p.fotoCompact} data-foto-expanded={p.fotoExpanded}
              role="button" tabindex="0" aria-label={`Ver perfil de ${p.nombre}`}>

              <!-- Vista compacta -->
              <div class="prof-card-compact">
                <img src={p.fotoCompact} alt={p.nombre} class="prof-foto prof-foto-bw" loading="lazy" />
                <img src={p.fotoExpanded} alt={p.nombre} class="prof-foto prof-foto-color" loading="lazy" />
                <div class="prof-info">
                  <p class="prof-nombre">{p.nombre}</p>
                  <p class="prof-cargo">{p.cargo}</p>
                </div>
              </div>

              <!-- Vista expandida -->
              <div class="prof-card-expanded">
                <div class="prof-exp-foto-col">
                  <img src={p.fotoExpanded} alt={p.nombre} class="prof-exp-foto" loading="lazy" />
                </div>
                <div class="prof-exp-body">
                  <button class="prof-exp-close" aria-label="Cerrar">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                      <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                  </button>
                  <p class="pexp-nombre">{p.nombre}</p>
                  <span class="pexp-tag">{p.cargo}</span>
                  <p class="pexp-bio">{p.bio}</p>
                </div>
              </div>

            </div>
          ))}
        </div>
      </div>

      <!-- Flecha derecha — sale fuera del inner -->
      <button class="prof-arrow prof-arrow--next" id="prof-next" aria-label="Siguiente">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    <!-- Flechas mobile -->
    <div class="prof-arrows-mobile">
      <button class="prof-arrow prof-arrow--mob-prev" aria-label="Anterior">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="prof-arrow prof-arrow--mob-next" aria-label="Siguiente">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- Botón -->
    <div class="profesores-boton-wrap">
      <a href="#" class="profesores-boton open-modal-cta">QUIERO DESCARGAR FOLLETO</a>
    </div>

  </div>
</section>

<style>
  /* ══ Sección ══ */
  .profesores-section {
    width: 100%;
    background: #FFCD00;
    padding-top: clamp(48px, 5vw, 80px);
    padding-bottom: clamp(48px, 5vw, 80px);
    padding-inline: clamp(20px, 16.67vw, 320px);
  }

  /* ── Inner ── */
  .profesores-inner {
    width: min(1285px, 100%);
    margin-inline: auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 3vw, 44px);
  }

  @media (max-width: 900px) {
    .profesores-section { padding-inline: 0; }
    .profesores-inner { padding: 0 0 0 16px; overflow: visible; }
    .profesores-titulo { padding-left: 28px; padding-right: 40px; }
    .prof-card-compact::after {
      background: linear-gradient(to top, rgba(0,0,0,0.35) 0%, transparent 35%);
    }
  }

  /* ══ Título: font-weight 500 (medium), "hoy" en 700 ══ */
  .profesores-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(22px, 2.08vw, 40px);
    line-height: 1.2;
    color: #1a1a1a;
    margin: 0;
  }
  .profesores-titulo strong {
    font-weight: 700;
  }

  /* ══ Shell del carrusel: position relative para flechas absolute ══ */
  .profesores-carousel-shell {
    position: relative;
    overflow: visible;
  }

  /* ══ Flechas: sencillas, position absolute fuera del inner ══ */
  .prof-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,0.4);
    background: transparent;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }
  .prof-arrow:hover { background: #1a1a1a; color: #FFCD00; border-color: #1a1a1a; }
  .prof-arrow:disabled { opacity: 0.25; cursor: default; }

  /* Salen fuera del inner */
  .prof-arrow--prev { left: -48px; }
  .prof-arrow--next { right: -48px; }

  /* ══ Overflow y track ══ */
  .profesores-overflow {
    overflow: hidden;
    width: 100%;
  }
  /* Cuando hay activa, el track sigue clipado */
  .profesores-overflow.has-active { overflow: hidden; }

  .profesores-track {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
    align-items: flex-start;
  }

  /* ══ Card compacta — más estrecha, gap mayor ══ */
  .prof-card {
    position: relative;
    flex-shrink: 0;
    width: 222px;   /* JS sobreescribe */
    height: 400px;
    border-radius: 20px;
    background: #fff;
    box-shadow: 0 3px 12px rgba(0,0,0,0.12);
    cursor: pointer;
    transition: width 0.45s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s;
    overflow: hidden;
  }
  .prof-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.18); }

  /* Activa: JS calcula compactW*2 + GAP para ocupar exactamente 2 slots */
  .prof-card.active {
    cursor: default;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    z-index: 10;
  }

  /* Vista compacta */
  .prof-card-compact {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    transition: opacity 0.25s ease;
  }
  .prof-card-compact::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.00) 35%, rgba(55, 55, 55, 0.78) 60%, #000 85%);
    z-index: 1;
    pointer-events: none;
  }
  .prof-card.active .prof-card-compact { opacity: 0; pointer-events: none; }

  .prof-info {
    position: relative;
    z-index: 2;
  }

  .prof-foto {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .prof-info {
    position: absolute;
    bottom: 14px; left: 14px; right: 14px;
    z-index: 2;
    margin-left: clamp(5px, 0.53vw, 11px);
  }
  .prof-nombre {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(13px, 1.52vw, 30px);
    line-height: 39px;
    color: #fff;
    margin: 0 0 clamp(1px, 0.15vw, 3px);
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }
  .prof-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: clamp(10px, 1.06vw, 21px);
    line-height: 0.5;
    color: rgba(255,255,255,0.85);
    margin: 0;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Vista expandida */
  .prof-card-expanded {
    position: absolute;
    inset: 0;
    display: flex;
    overflow: hidden;
    background: #fff;
    border-radius: inherit;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease 0.2s;
  }
  .prof-card.active .prof-card-expanded {
    opacity: 1;
    pointer-events: auto;
  }

  .prof-exp-foto-col {
    width: 180px;
    flex-shrink: 0;
    align-self: stretch;
    border-radius: 24px 0 0 24px;
    overflow: hidden;
  }
  .prof-exp-foto {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .prof-exp-body {
    flex: 1;
    padding: clamp(12px, 1.37vw, 27px) clamp(12px, 1.37vw, 27px) clamp(12px, 1.37vw, 27px) clamp(11px, 1.21vw, 24px);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.1) transparent;
    position: relative;
  }
  .prof-exp-body::-webkit-scrollbar { width: 3px; }
  .prof-exp-body::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 3px; }

  .pexp-nombre {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(18px, 2.12vw, 42px);
    line-height: 1.2;
    color: #000;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-right: clamp(21px, 2.43vw, 48px); /* espacio para el botón cerrar */
  }
  .pexp-tag {
    display: inline-block;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(7px, 0.76vw, 15px);
    line-height: 1.35;
    color: #fff;
    padding: clamp(3px, 0.30vw, 6px) clamp(8px, 0.91vw, 18px);
    border-radius: 20px;
    width: fit-content;
  }
  .pexp-bio {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(10px, 1.06vw, 21px);
    line-height: 20px;
    color: #000000;
    margin: 0;
  }

  /* Botón cerrar */
  .prof-exp-close {
    position: absolute;
    top: 14px; right: 14px;
    width: 26px; height: 26px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,0.15);
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.18s;
    z-index: 5;
    color: #000;
  }
  .prof-exp-close:hover { background: #f0f0f0; }

  /* ══ Flechas mobile: ocultas en desktop ══ */
  .prof-arrows-mobile { display: none; }

  /* ══ Botón sección ══ */
  .profesores-boton-wrap {
    display: flex;
    justify-content: flex-end;
  }
  .profesores-boton {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 clamp(18px, 2.12vw, 42px);
    border-radius: 999px;
    background: #1a1a1a;
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(8px, 0.91vw, 18px);
    letter-spacing: 0.08em;
    text-decoration: none;
    white-space: nowrap;
