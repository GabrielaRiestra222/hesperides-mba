</style>

<script>
  const track    = document.getElementById('profesores-track') as HTMLElement;
  const overflow = document.getElementById('profesores-overflow') as HTMLElement;
  const prevBtn  = document.getElementById('prof-prev') as HTMLButtonElement;
  const nextBtn  = document.getElementById('prof-next') as HTMLButtonElement;
  const mobPrev  = document.querySelector<HTMLButtonElement>('.prof-arrow--mob-prev');
  const mobNext  = document.querySelector<HTMLButtonElement>('.prof-arrow--mob-next');
  const cards    = Array.from(document.querySelectorAll<HTMLElement>('.prof-card'));
  const GAP      = 20;
  let current    = 0;
  let compactW   = 140;

  // Duplicar cards al final del track solo en desktop para evitar que se corte la última
  if (window.innerWidth > 860) {
    cards.forEach(card => {
      const clone = card.cloneNode(true) as HTMLElement;
      clone.setAttribute('aria-hidden', 'true');
      clone.classList.add('prof-card--clone');
      track.appendChild(clone);
    });
  }

  function vis() {
    const w = window.innerWidth;
    return w >= 1200 ? 5 : w >= 900 ? 4 : w >= 650 ? 3 : 1;
  }

  function expandedW() {
    return compactW * 2 + GAP;
  }

  function setWidths() {
    const outer = (track.parentElement as HTMLElement).offsetWidth;
    const v = vis();
    const w = window.innerWidth;
    if (w < 650) {
      compactW = Math.floor(w * 0.72);
    } else {
      compactW = Math.floor((outer - GAP * (v - 1)) / v);
    }
    cards.forEach(c => {
      if (!c.classList.contains('active')) {
        c.style.width = compactW + 'px';
      }
    });
  }

  function cardStep() { return compactW + GAP; }
  function maxI() { return Math.max(0, cards.length - vis()); }

  function goTo(i: number) {
    if (i < 0) i = maxI();
    if (i > maxI()) i = 0;
    current = i;
    track.style.transition = 'transform 0.5s ease';
    track.style.transform = `translateX(-${current * cardStep()}px)`;
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
  mobPrev?.addEventListener('click', () => goTo(current - 1));
  mobNext?.addEventListener('click', () => goTo(current + 1));

  /* Expand / collapse */
  function closeActive() {
    const active = document.querySelector<HTMLElement>('.prof-card.active');
    if (active) {
      active.classList.remove('active');
      active.style.width = compactW + 'px';
      overflow.classList.remove('has-active');
    }
  }

  cards.forEach(card => {
    card.addEventListener('click', (e) => {
      if (isDragging) return;
      if ((e.target as HTMLElement).closest('.prof-exp-close')) return;
      if (card.classList.contains('active')) return;
      closeActive();
      card.classList.add('active');

      if (window.innerWidth <= 900) {
        card.style.width = Math.floor(window.innerWidth * 0.85) + 'px';
        overflow.classList.add('has-active');
      } else {
        card.style.width = expandedW() + 'px';
        overflow.classList.add('has-active');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const cardRect = card.getBoundingClientRect();
            const overflowRect = overflow.getBoundingClientRect();
            if (cardRect.right > overflowRect.right) {
              const extra = cardRect.right - overflowRect.right + 20;
              const match = track.style.transform.match(/translateX\(-?([\d.]+)/);
              const currentX = match ? parseFloat(match[1]) : 0;
              track.style.transition = 'transform 0.3s ease';
              track.style.transform = `translateX(-${currentX + extra}px)`;
            }
          });
        });
      }
    });

    card.querySelector('.prof-exp-close')?.addEventListener('click', (e) => {
      e.stopPropagation();
      closeActive();
      setWidths();
    });
  });

  document.addEventListener('click', (e) => {
    const path = e.composedPath ? e.composedPath() : [e.target];
    const insideCard = path.some(el => (el as HTMLElement).classList?.contains('prof-card'));
    if (!insideCard) closeActive();
  });

  // Touch swipe (carrusel) — distinguir swipe de tap
  let tx = 0;
  let isDragging = false;
  track.addEventListener('touchstart', e => {
    tx = e.changedTouches[0].screenX;
  }, { passive: true });
  track.addEventListener('touchmove', () => { isDragging = true; }, { passive: true });
  track.addEventListener('touchend', e => {
    setTimeout(() => { isDragging = false; }, 50);
    if ((e.target as HTMLElement).closest('.prof-card')) return;
    const diff = tx - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
  }, { passive: true });

  window.addEventListener('resize', () => {
    closeActive();
    setWidths();
    goTo(Math.min(current, maxI()));
  });

  setWidths();
  goTo(0);
</script>