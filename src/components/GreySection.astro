---
const tabs = [
  { label: "PLAN DE ESTUDIOS",          type: "plan"         },
  { label: "COMPETENCIAS Y HABILIDADES", type: "competencias" },
  { label: "CRÉDITOS",                  type: "creditos"     },
  { label: "PRÁCTICAS PROFESIONALES",   type: "practicas"    },
];

const testimonials = [
  {
    name: "Andoni Cortazar Andueza",
    cargo: "Directivo en empresa internacional",
    text: ".h es una experiencia transformadora. Al final es un viaje en el que yo partía como un outsider, alguien que venía de otra zona de confort distinta. Entonces es algo que te saca de tu zona de confort y en mi caso, por lo menos, me ayudó a aprender, a entender y, sobre todo, a liderar de una forma diferente.",
    img: "src/img/Andoni_Cortazar_Andueza_color.jpg"
  },
  {
    name: "Jorge Muñoz",
    cargo: "Emprendedor y consultor",
    text: "A veces pensamos que vamos a la escuela a que nos enseñen y que no tenemos que hacer nada, que mágicamente aprendemos. Sin embargo, cuando uno más aprende es viendo vídeos, interiorizando conceptos, explicándole lo aprendido a otra persona. Se aprende de forma activa, no de forma pasiva.",
    img: "src/img/Jorge_Manuel_Mun_oz_Rodri_guez_color.jpg"
  },
  {
    name: "Jaime Gil Martínez",
    cargo: "Ejecutivo en Accenture",
    text: "Mi experiencia en la Universidad de las Hespérides se puede definir como un proceso de enriquecimiento intelectual y de descubrimiento personal, tanto en valores y principios como en el entendimiento del funcionamiento del mundo.",
    img: "src/img/LinkedIn_profile_picture_color_copy.jpg"
  },
  {
    name: "Miguel Núñez",
    cargo: "Emprendedor",
    text: "Algo que yo lo voy viendo y cada vez me voy sorprendiendo más de cómo los profesores, junto con los alumnos, se crea una comunidad tan libre y tan responsable.",
    img: "src/img/miguel_nun_ez-G_Emprendimiento_copy.jpg"
  }
];
---

<section class="section-wrapper">
  <div class="section-inner">

    <!-- ═══════════ FAQ ═══════════
         Grid de 4 columnas.
         Cuando un ítem está abierto, su card
         se posiciona absolute y ocupa 2 cols.
    ═════════════════════════════ -->
    <div class="faq-grid" id="faq-grid">

      {tabs.map((tab, i) => (
        <div class="faq-col" data-col={i}>

          <!-- Título / trigger — sin ninguna línea -->
          <button class="faq-trigger" data-index={i} aria-expanded="false">
            <span class="faq-label">{tab.label}</span>
            <span class="faq-icon">+</span>
          </button>

          <!-- Card: oculta por defecto, doble ancho al abrir -->
          <div class="faq-card-wrap" id={`faq-wrap-${i}`} aria-hidden="true">
            <div class="faq-card" id={`faq-card-${i}`}>

              {/* ── PLAN ── */}
              {tab.type === "plan" && (
                <div class="card-plan">
                  <div class="sem-header">PRIMER SEMESTRE</div>
                  <table class="ptable">
                    <thead><tr><th>Denominación de la asignatura</th><th>ECTS</th><th>Carácter</th></tr></thead>
                    <tbody>
                      <tr><td>Economía para los Negocios <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Análisis Financiero Aplicado <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Dirección Estratégica <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Estrategia de Innovación Empresarial <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Estrategia de Inversión <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Marketing Estratégico <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Liderazgo y Gestión de Equipos <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Negocios y Ciclos Económicos <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Metodologías de Investigación <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Pensamiento Económico y Social (inglés) <em>[PDF]</em></td><td>3</td><td>Obligatoria</td></tr>
                      <tr><td>Inteligencia Artificial Aplicada a la empresa.</td><td>3</td><td>Obligatoria</td></tr>
                      <tr class="sub"><td><strong>Créditos semestre</strong></td><td><strong>33</strong></td><td></td></tr>
                    </tbody>
                  </table>
                  <div class="sem-header" style="margin-top:18px">SEGUNDO SEMESTRE</div>
                  <table class="ptable">
                    <thead><tr><th>Denominación de la asignatura</th><th>ECTS</th><th>Carácter</th></tr></thead>
                    <tbody>
                      <tr><td>Especialidad</td><td>18</td><td>Optativa</td></tr>
                      <tr><td>Prácticas Académicas Externas <em>[PDF]</em></td><td>6</td><td>Prácticas externas</td></tr>
                      <tr><td>Trabajo de Fin de Máster <em>[PDF]</em></td><td>6</td><td>TFM</td></tr>
                      <tr class="sub"><td><strong>Créditos semestre 2</strong></td><td><strong>30</strong></td><td></td></tr>
                    </tbody>
                  </table>
                  <div class="total-bar"><span>Créditos Totales</span><span>63</span></div>
                  <div class="esp-grid">
                    <div>
                      <div class="esp-header">Especialidad en Finanzas</div>
                      <table class="ptable">
                        <thead><tr><th>Asignatura</th><th>ECTS</th></tr></thead>
                        <tbody>
                          <tr><td>Banca y Gestión de Patrimonios <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Fuentes de Financiación <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Instrumentos Financieros Derivados <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Inversión en Valor <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Opciones Reales <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Innovaciones Financieras <em>[PDF]</em></td><td>3</td></tr>
                        </tbody>
                      </table>
                    </div>
                    <div>
                      <div class="esp-header">Especialidad en Marketing</div>
                      <table class="ptable">
                        <thead><tr><th>Asignatura</th><th>ECTS</th></tr></thead>
                        <tbody>
                          <tr><td>Análisis del Comportamiento del Consumidor <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Psicología del Marketing <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Marketing móvil y Comercio Electrónico <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Creatividad y Herramientas de Imagen de Marca <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Estrategia Basada en Datos <em>[PDF]</em></td><td>3</td></tr>
                          <tr><td>Redes Sociales e Inbound Marketing <em>[PDF]</em></td><td>3</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              )}

              {/* ── COMPETENCIAS ── */}
              {tab.type === "competencias" && (
                <div class="card-text">
                  <p>El proceso de aprendizaje de la Universidad de las Hespérides está diseñado para facilitar el crecimiento personal, el desarrollo de habilidades y el florecimiento intelectual para así tener las herramientas con que lograr el éxito en tu vida profesional. El eje de todo el proceso de aprendizaje son las competencias que adquirirás a lo largo de tus estudios. Dentro de este marco, los contenidos no son un fin en sí mismo, sino un medio con los que alcanzar estas competencias. Tus profesores lo saben y por eso han diseñado sus cursos pensando en lo que aprenderás a hacer y no solo en lo que respondas en un examen.</p>
                  <p class="q">¿Qué sabrás hacer con el Máster Universitario en Administración y Dirección de Empresas?</p>
                  <p>Al terminar el programa de estudios, podrás crear estrategias de innovación que, sumadas a tu habilidad para estructurar equipos de trabajo eficientes, permitirán llevar tu visión empresarial a la realidad. Tendrás la capacidad de identificar el impacto de las políticas económicas para manejar riesgos e identificar nuevas oportunidades de negocios, por ejemplo, en períodos inflacionarios. En fin, tendrás la capacidad y la visión para ser un líder empresarial innovador que sabe navegar la incertidumbre y llevar proyectos a buen puerto.</p>
                </div>
              )}

              {/* ── CRÉDITOS ── */}
              {tab.type === "creditos" && (
                <div class="card-cred">
                  <div class="cred-head"><span>Carácter</span><span>Créditos</span></div>
                  <table class="ctable">
                    <tbody>
                      <tr><td>Obligatorias</td><td>30</td></tr>
                      <tr><td>Optativas</td><td>18</td></tr>
                      <tr><td>Prácticas externas</td><td>6</td></tr>
                      <tr><td>Trabajo de Fin de Máster</td><td>6</td></tr>
                      <tr class="ctotal"><td><strong>Total</strong></td><td><strong>60</strong></td></tr>
                    </tbody>
                  </table>
                </div>
              )}

              {/* ── PRÁCTICAS ── */}
              {tab.type === "practicas" && (
                <div class="card-text">
                  <p>Gracias a los convenios de colaboración de .h, podrás cursar tus prácticas externas curriculares del Máster Universitario en Administración y Dirección de Empresas al más alto nivel. Te podrás beneficiar de los acuerdos con la Fundación Universidad-Empresa (programa e-Start), Lopesan Hotel Management, Expomeloneras SA, Cordial Canarias Hotels &amp; Resorts, Costa Volcán SA, Binter Canarias, Banco Latinoamericano de Comercio Exterior y Domingo Alonso Group, entre otras instituciones y empresas que te permitirán conectarte con tu campo profesional.</p>
                  <p>Al ser estudiante de .h, formarás parte del entorno colaborativo del Make Impact Consortium (MIC), liderado por el Massachusetts Institute of Technology (MIT), una comunidad internacional de universidades con ideas afines para el aprendizaje y el beneficio mutuo. Podrás participar en los retos que el MIC, en alianza con distintas empresas y organizaciones, lanza para resolver problemas reales y crear impacto positivo en la sociedad.</p>
                  <p>También tendrás la posibilidad de llevar adelante tus prácticas en el ámbito de la propia universidad, en proyectos como el Bootcamp para emprendedores, el vivero y acelerador de empresas, el Makerspace y el Observatorio de Coyuntura Económica.</p>
                </div>
              )}

            </div>
          </div>
        </div>
      ))}

    </div>

    <!-- ═══════════ TÍTULO ═══════════ -->
    <h3 class="section-title">Nuestros alumnos ya conocen el éxito</h3>

    <!-- ═══════════ CARRUSEL ═══════════ -->
    <div class="carousel-wrapper">
      <!-- Flechas laterales (desktop) -->
      <button class="carousel-arrow carousel-arrow--desktop" id="arrow-prev" aria-label="Anterior">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="carousel-col">
        <div class="carousel-outer">
          <div class="carousel-track" id="carousel-track">
            {testimonials.map((t) => (
              <div class="alumni-card" tabindex="0" role="button">
                <div class="card-front">
                  <img src={t.img} alt={`Foto de ${t.name}`} class="card-photo" loading="lazy" />
                  <div class="card-front-footer">
                    <p class="cfquote">"{t.text}"</p>
                    <p class="cfname">{t.name}</p>
                  </div>
                </div>
                <div class="card-back">
                  <button class="card-close" aria-label="Cerrar">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
                      <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                  </button>
                  <div class="cbphoto">
                    <img src={t.img} alt="" loading="lazy" aria-hidden="true" />
                  </div>
                  <div class="cbbody">
                    <p class="cbquote">"{t.text}"</p>
                    <div class="cbmeta">
                      <p class="cbname">{t.name}</p>
                      <p class="cbcargo">{t.cargo}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <!-- Fila inferior mobile: flechas + botón -->
        <div class="carousel-bottom">
          <div class="carousel-arrows-row">
            <button class="carousel-arrow carousel-arrow--mobile" aria-label="Anterior">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="carousel-arrow carousel-arrow--mobile" aria-label="Siguiente">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
      <!-- Flecha derecha desktop -->
      <button class="carousel-arrow carousel-arrow--desktop" id="arrow-next" aria-label="Siguiente">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- CTA desktop -->
    <div class="cta-wrap cta-wrap--desktop">
      <a href="#" class="cta-btn">QUIERO APRENDER MÁS</a>
    </div>

  </div>
</section>

<style>
  .section-wrapper {
    background: #E5E5E5;
    padding: 80px 0 96px;
    position: relative;
    z-index: 10;
  }
  .section-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ═══════════════════════════════════
     FAQ — inline-flex con gap 42px
     Línea decorativa SOLO en el trigger
  ═══════════════════════════════════ */
  .faq-grid {
    display: inline-flex;
    align-items: flex-start;
    gap: 42px;
    margin-bottom: 64px;
    position: relative;
    width: 100%;
  }

  @media (max-width: 767px) {
    .faq-grid { flex-direction: column; gap: 0; }
  }

  /* Columna */
  .faq-col {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  /* Línea decorativa vertical — SOLO en el trigger, no se alarga */
  .faq-col:not(:first-child) .faq-trigger::before {
    content: '';
    position: absolute;
    left: -21px; /* mitad del gap */
    top: 0;
    bottom: 0;
    width: 1.5px;
    background: #000;
    height: 100%; /* solo la altura del trigger */
  }
  .faq-trigger { position: relative; }

  @media (max-width: 767px) {
    .faq-col:not(:first-child) .faq-trigger::before { display: none; }
    .faq-col { border-bottom: none; width: 100%; }
    .faq-trigger {
      padding: 16px 0 !important;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.06em;
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .faq-icon { flex-shrink: 0; margin-left: auto; }
  }

  /* Trigger — compacto */
  .faq-trigger {
    width: 100%;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 16px 12px 16px 0;
    color: #000;
    font-family: 'NotoSansHK-Bold-Alphabetic', 'Noto Sans HK', Georgia, serif;
    font-size: 24px;
    font-weight: 700;
    line-height: 28px;
    text-align: left;
    gap: 6px;
    transition: opacity 0.2s;
  }
  @media (min-width: 768px) {
    .faq-trigger { font-size: 16px; line-height: 20px; padding: 18px 10px 18px 0; }
  }
  .faq-trigger:hover { opacity: 0.5; }
  .faq-label { flex: 1; }
  .faq-icon {
    font-size: 26px;
    font-weight: 300;
    flex-shrink: 0;
    line-height: 1;
    transition: transform 0.38s cubic-bezier(0.4,0,0.2,1);
  }
  .faq-trigger[aria-expanded="true"] .faq-icon { transform: rotate(45deg); }

  /* ── Card wrapper: inicialmente colapsado, luego se despliega ── */
  .faq-card-wrap {
    /* Ocupa 0 altura cuando está cerrado */
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.52s cubic-bezier(0.4,0,0.2,1),
      opacity 0.3s ease;
  }

  .faq-card-wrap.open {
    max-height: 2800px;
    opacity: 1;
  }

  /* ── La card en sí — por defecto ocupa 1 col ── */
  .faq-card {
    background: #fff;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 28px rgba(0,0,0,0.11), 0 1px 4px rgba(0,0,0,0.06);
    margin-right: 0;
    /* Doble ancho: se anula el overflow del padre con JS */
    width: 100%;
    box-sizing: border-box;
  }

  /*
    En desktop, cuando la card está abierta queremos que ocupe
    el ancho de 2 columnas. Lo hacemos con una clase que se añade
    via JS al faq-card-wrap, y hacemos overflow visible + ancho 200%.
  */
  @media (min-width: 768px) {
    /* Card se expande al doble: overflow visible + 200% */
    .faq-card-wrap.open.double {
      overflow: visible;
    }
    .faq-card-wrap.open.double .faq-card {
      width: 200%;
    }
    .faq-card-wrap.open.double.flip .faq-card {
      width: 200%;
      margin-left: -100%;
    }
  }

  /* ── Contenidos de las cards ── */
  .card-text p {
    font-size: 13px;
    line-height: 1.75;
    color: #222;
    margin: 0 0 14px;
  }
  .card-text p:last-child { margin-bottom: 0; }
  .card-text .q {
    font-weight: 700;
    color: #000;
    font-size: 14px;
  }

  /* Plan */
  .sem-header {
    display: inline-block;
    background: #FFCD00;
    color: #000;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.07em;
    padding: 7px 14px;
    border-radius: 5px;
    margin-bottom: 12px;
  }
  .ptable {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    margin-bottom: 6px;
  }
  .ptable th {
    text-align: left;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #bbb;
    padding: 0 6px 8px 0;
    border-bottom: 1px solid #ececec;
  }
  .ptable th:nth-child(2),
  .ptable th:nth-child(3) { text-align: center; }
  .ptable td {
    padding: 7px 6px 7px 0;
    border-bottom: 1px solid #f3f3f3;
    color: #111;
    line-height: 1.4;
    font-size: 12px;
  }
  .ptable td:nth-child(2),
  .ptable td:nth-child(3) { text-align: center; color: #666; white-space: nowrap; }
  .ptable tr:last-child td { border-bottom: none; }
  .ptable tr.sub td {
    border-top: 1.5px solid #e0e0e0;
    border-bottom: none;
    padding-top: 10px;
  }
  .ptable em { font-size: 10px; color: #bbb; font-style: normal; }
  .total-bar {
    display: flex;
    justify-content: space-between;
    background: #FFCD00;
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 700;
    color: #000;
    margin: 14px 0;
  }
  .esp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 4px;
  }
  @media (max-width: 600px) { .esp-grid { grid-template-columns: 1fr; } }
  .esp-header {
    background: #FFCD00;
    color: #000;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.05em;
    padding: 7px 12px;
    border-radius: 5px;
    margin-bottom: 10px;
  }

  /* Créditos */
  .cred-head {
    display: flex;
    justify-content: space-between;
    background: #FFCD00;
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 800;
    color: #000;
    margin-bottom: 16px;
  }
  .ctable {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .ctable td {
    padding: 12px 0;
    border-bottom: 1px solid #f0f0f0;
    color: #111;
  }
  .ctable td:last-child { text-align: right; font-weight: 600; color: #333; }
  .ctable tr.ctotal td {
    border-bottom: none;
    border-top: 1.5px solid #ddd;
    padding-top: 14px;
    font-size: 15px;
  }

  /* ═══════════════════════════════════
     TÍTULO
  ═══════════════════════════════════ */
  .section-title {
    font-family: 'NotoSansHK-Bold-Alphabetic', 'Noto Sans HK', Georgia, serif;
    font-size: 26px;
    font-weight: 400;
    line-height: 1.3;
    color: #000;
    text-align: left;
    margin-bottom: 32px;
  }

  /* ═══════════════════════════════════
     CARRUSEL
  ═══════════════════════════════════ */
  .carousel-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .carousel-outer { flex: 1; overflow: hidden; }
  .carousel-col { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 20px; overflow: hidden; }

  /* Desktop/mobile visibility */
  .carousel-arrow--mobile { display: none; }
  .carousel-bottom { display: none; }

  /* Center when all 4 cards fit */
  @media (min-width: 1100px) {
    .carousel-outer { display: flex; justify-content: center; }
    .carousel-track { justify-content: center; }
  }
  .carousel-track {
    display: flex;
    gap: 12px;
    transition: transform 0.52s cubic-bezier(0.4,0,0.2,1);
    will-change: transform;
    align-items: flex-start;
  }

  /* Card alumno — más estrecha para que 4 quepan a primera vista */
  .alumni-card {
    position: relative;
    width: 248px;
    height: 370px;
    flex-shrink: 0;
    border-radius: 24px;
    background: #fff;
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 4px 24px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);
    transition: height 0.42s cubic-bezier(0.4,0,0.2,1);
  }
