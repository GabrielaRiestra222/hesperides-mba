    .faq-card { padding: clamp(24px, 2.5vw, 48px); }
    .cbquote { font-size: clamp(16px, 1.2vw, 20px); line-height: 1.35; }
    .cbname { font-size: clamp(9px, 0.9vw, 16px); text-transform: capitalize; margin-top: auto; padding-top: clamp(16px, 1.8vw, 28px); margin-bottom: 0; line-height: 1; }
    .cbcargo { font-size: clamp(8px, 0.75vw, 13px); text-transform: capitalize; margin-top: clamp(-8px, -0.6vw, -4px); padding-top: 0; line-height: 1; }
  }

  @media (max-width: 1499px) and (min-width: 901px) {
    .cbname { font-size: clamp(10px, 1.05vw, 18px); }
    .cbcargo { margin-top: clamp(-2px, -0.15vw, 0px); }
  }

  @media (min-width: 1500px) {
    .alumni-card { height: 420px; }
    .card-front { height: 420px; }
    .cfquote, .cbquote { font-size: clamp(12px, 0.85vw, 14px); }
    .cbcargo { font-size: clamp(11px, 0.8vw, 13px); }
    .cfname, .cbname { font-size: clamp(13px, 1vw, 16px); margin-bottom: clamp(8px, 0.8vw, 14px); }
  }

</style>

<script>
  // ══════════════════════════════════════
  // FAQ — cards en flujo, empujan contenido
  // ══════════════════════════════════════
  const faqGrid  = document.getElementById('faq-grid') as HTMLElement;
  const triggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');

  function closeAll() {
    triggers.forEach((t, i) => {
      t.setAttribute('aria-expanded', 'false');
      const w = document.getElementById(`faq-wrap-${i}`);
      if (w) w.classList.remove('open');
    });
  }

  triggers.forEach((trigger, idx) => {
    const wrap = document.getElementById(`faq-wrap-${idx}`);
    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      closeAll();
      if (!isOpen && wrap) {
        trigger.setAttribute('aria-expanded', 'true');
        wrap.classList.add('open');
      }
    });
  });

  document.addEventListener('click', (e) => {
    if (!faqGrid?.contains(e.target as Node)) closeAll();
  });

  // Scroll dot indicator en cada alumni card
  document.querySelectorAll<HTMLElement>('.alumni-card').forEach(card => {
    const textEl = card.querySelector<HTMLElement>('.card-back');
    const dot = card.querySelector<HTMLElement>('.card-scroll-dot');
    const dotTrack = card.querySelector<HTMLElement>('.card-scroll-track');
    if (!textEl || !dot || !dotTrack) return;
    if (textEl.scrollHeight <= textEl.clientHeight) {
      dotTrack.style.display = 'none';
      return;
    }
    textEl.addEventListener('scroll', () => {
      const scrollPercent = textEl.scrollTop / (textEl.scrollHeight - textEl.clientHeight);
      const maxTop = dotTrack.offsetHeight - dot.offsetHeight;
      dot.style.top = (scrollPercent * maxTop) + 'px';
    });
  });

  // ══════════════════════════════════════
  // CARRUSEL
  // ══════════════════════════════════════
  const track    = document.getElementById('carousel-track') as HTMLElement;
  const prevBtn  = document.getElementById('arrow-prev')     as HTMLButtonElement;

  const nextBtn  = document.getElementById('arrow-next')     as HTMLButtonElement;
  const cards    = document.querySelectorAll<HTMLElement>('.alumni-card');
  const mobPrev  = document.querySelector<HTMLButtonElement>('.c-arrow--mob-prev');
  const mobNext  = document.querySelector<HTMLButtonElement>('.c-arrow--mob-next');

  let current = 0;
  const total = cards.length;

  function cardStep() {
    const card = cards[0];
    if (!card) return 260;
    const gap = parseFloat(getComputedStyle(track).gap) || 16;
    return card.offsetWidth + gap;
  }

  function goTo(i: number) {
    current = Math.max(0, Math.min(i, total - 1));
    track.style.transform = `translateX(-${current * cardStep()}px)`;
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current >= total - 1;
    if (mobPrev) mobPrev.disabled = current === 0;
    if (mobNext) mobNext.disabled = current >= total - 1;
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  mobPrev?.addEventListener('click', () => goTo(current - 1));
  mobNext?.addEventListener('click', () => goTo(current + 1));

  // Touch swipe
  let tx = 0;
  track.addEventListener('touchstart', e => { tx = e.changedTouches[0].screenX; }, { passive: true });
  track.addEventListener('touchend', e => {
    const diff = tx - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
  }, { passive: true });

  // Toggle card back on click/tap
  cards.forEach(card => {
    card.addEventListener('click', e => {
      const closeBtn = card.querySelector('.card-close');
      if (closeBtn?.contains(e.target as Node)) {
        card.classList.remove('expanded');
        return;
      }
      if (!card.classList.contains('expanded')) {
        cards.forEach(c => c.classList.remove('expanded'));
        card.classList.add('expanded');
      }
    });
  });

  window.addEventListener('resize', () => goTo(current));
  goTo(0);
</script>