}

  @media (min-width: 901px) {
    .faq-icon { font-size: clamp(18px, 1.8vw, 30px); display: flex; align-items: center; justify-content: center; width: clamp(24px, 2vw, 36px); height: clamp(24px, 2vw, 36px); }
    .cta-btn { font-weight: 500; padding-block: clamp(6px, 0.6vw, 10px); padding-inline: clamp(14px, 1.5vw, 24px); font-size: clamp(9px, 0.99vw, 20px); letter-spacing: 0.07em; }
    .cta-btn:hover { background: #FFCD00; color: #000; opacity: 1; }
    .c-arrow { border: none; border-radius: 0; background: transparent; }
