---
// AprendeMejores.astro
const profesores = [
  { id: 1,  nombre: "Miguel Anxo Bastos",   cargo: "Profesor visitante - Universidad de las Hespérides", foto: "/img/aprende/allo/miguel-anxo-bastos.jpg",    fotoColor: "/img/aprende/color/miguel-anxo-bastos.jpg",    logo: "/img/aprende/logos/hesperides.png",    logoAlt: "Universidad de las Hespérides" },
  { id: 2,  nombre: "Joan Tubau",            cargo: "Fundador - Podcast Kapital",                         foto: "/img/aprende/allo/joan-tubau.jpg",             fotoColor: "/img/aprende/color/joan-tubau.jpg",             logo: "/img/aprende/logos/kapital.png",       logoAlt: "Kapital" },
  { id: 3,  nombre: "Marc Urgell",           cargo: "CEO - Abast Global",                                 foto: "/img/aprende/allo/marc-urgell.jpg",            fotoColor: "/img/aprende/color/marc-urgell.jpg",            logo: "/img/aprende/logos/abast.png",         logoAlt: "Abast" },
  { id: 4,  nombre: "Gerard Caelles",        cargo: "CBO - SpliceBio",                                    foto: "/img/aprende/allo/gerard-caelles.jpg",         fotoColor: "/img/aprende/color/gerard-caelles.jpg",         logo: "/img/aprende/logos/splicebio.png",     logoAlt: "SpliceBio" },
  { id: 5,  nombre: "Lourdes Fuster",        cargo: "Global Head of CRM - Wallapop",                      foto: "/img/aprende/allo/lourdes-fuster.jpg",         fotoColor: "/img/aprende/color/lourdes-fuster.jpg",         logo: "/img/aprende/logos/wallapop.png",      logoAlt: "Wallapop" },
  { id: 6,  nombre: "Joan Cortadellas",      cargo: "Marketing Director - Trenes.com",                    foto: "/img/aprende/allo/joan-cortadellas.jpg",       fotoColor: "/img/aprende/color/joan-cortadellas.jpg",       logo: "/img/aprende/logos/trenes.png",        logoAlt: "Trenes.com" },
  { id: 7,  nombre: "José Juan González",    cargo: "CEO - Canaragua",                                    foto: "/img/aprende/allo/jose-juan-gonzalez.jpg",     fotoColor: "/img/aprende/color/jose-juan-gonzalez.jpg",     logo: "/img/aprende/logos/canaragua.png",     logoAlt: "Canaragua" },
  { id: 8,  nombre: "Oliver Alonso",         cargo: "Presidente - Domingo Alonso Group",                  foto: "/img/aprende/allo/oliver-alonso.jpg",          fotoColor: "/img/aprende/color/oliver-alonso.jpg",          logo: "/img/aprende/logos/domingo-alonso.png",logoAlt: "Domingo Alonso Group" },
  { id: 9,  nombre: "Sebastián Cerezo",      cargo: "Socio - Moira Capital Partners",                     foto: "/img/aprende/allo/sebastian-cerezo.jpg",       fotoColor: "/img/aprende/color/sebastian-cerezo.jpg",       logo: "/img/aprende/logos/moira.png",         logoAlt: "Moira" },
  { id: 10, nombre: "José Martínez",         cargo: "CEO - Grupo Martínez Abolafio",                      foto: "/img/aprende/allo/jose-martinez.jpg",          fotoColor: "/img/aprende/color/jose-martinez.jpg",          logo: "/img/aprende/logos/grupo-martinez.png",logoAlt: "Grupo Martínez" },
  { id: 11, nombre: "Martín Eugenio Pérez",  cargo: "Presidente - Aloe Lanzarote Plus",                   foto: "/img/aprende/allo/martin-eugenio-perez.jpg",   fotoColor: "/img/aprende/color/martin-eugenio-perez.jpg",   logo: "/img/aprende/logos/aloe-plus.png",     logoAlt: "Aloe Plus" },
  { id: 12, nombre: "José Julio Artiles",    cargo: "CEO - Satocan",                                      foto: "/img/aprende/allo/jose-julio-artiles.jpg",     fotoColor: "/img/aprende/color/jose-julio-artiles.jpg",     logo: "/img/aprende/logos/satocan.png",       logoAlt: "Satocan" },
  { id: 13, nombre: "Rodolfo Núñez",         cargo: "Presidente de Binter",                               foto: "/img/aprende/allo/rodolfo-nunez.jpg",          fotoColor: "/img/aprende/color/rodolfo-nunez.jpg",          logo: "/img/aprende/logos/binter.png",        logoAlt: "Binter" },
];
---

<section class="aprende-section">
  <div class="aprende-header">
    <h2 class="aprende-titulo">
      <span class="titulo-bold">CEOs, empresarios y directivos reales, </span><span class="titulo-normal">contigo en directo.</span>
    </h2>
  </div>

  <div class="cards-container" id="cards-container">
    {profesores.map((profesor) => (
      <div
        class="profesor-card"
        data-id={profesor.id}
        style={`--foto: url('${profesor.foto}'); --foto-color: url('${profesor.fotoColor}')`}
        role="button"
        tabindex="0"
        aria-label={`Ver perfil de ${profesor.nombre}`}
      >
        {/* Logo centrado — visible en estado default */}
        {profesor.logo && (
          <div class="logo-empresa">
            <img src={profesor.logo} alt={profesor.logoAlt} />
          </div>
        )}

        {/* Info — visible en hover y expanded */}
        <div class="profesor-info">
          <div class="info-logo-left">
            {profesor.logo && <img src={profesor.logo} alt={profesor.logoAlt} class="info-logo" />}
          </div>
          <div class="info-text-right">
            <p class="profesor-nombre">{profesor.nombre}</p>
            <p class="profesor-cargo">{profesor.cargo}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="aprende-arrows">
    <button class="aprende-arrow aprende-arrow--prev" aria-label="Anterior" id="aprende-prev">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="aprende-arrow aprende-arrow--next" aria-label="Siguiente" id="aprende-next">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>
</section>

<style>
  .aprende-section {
    width: 100%;
    background: #fff;
    padding: clamp(29px, 3.64vw, 72px) 0 clamp(34px, 4.25vw, 84px);
    overflow: hidden;
  }

  .aprende-header {
    text-align: center;
    margin-bottom: clamp(21px, 2.43vw, 48px);
    padding-inline: clamp(20px, 5vw, 100px);
  }

  .aprende-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 400;
    margin: 0;
    line-height: 1.2;
  }

  .titulo-bold   { color: #FFCD00; font-weight: 700; }
  .titulo-normal { color: #FFCD00; font-weight: 400; }

  .cards-container {
    display: flex;
    flex-direction: row;
    gap: clamp(6px, 0.5vw, 10px);
    align-items: stretch;
    width: 100%;
    overflow: hidden;
    padding-inline: 0;
  }

  /* Card compacta */
  .profesor-card {
    position: relative;
    flex: 1;
    min-width: 0;
    height: clamp(160px, 16vw, 256px);
    border-radius: clamp(10px, 1.03vw, 17px);
    overflow: hidden;
    cursor: pointer;
    background: var(--foto) center 20% / cover no-repeat;
    transition: flex 0.3s ease, border-radius 0.3s ease, background-position 0.3s ease;
    display: none;
  }

  .profesor-card.visible {
    display: block;
  }

  .profesor-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.4) 0%, transparent 100%);
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
  }

  /* Hover desktop — solo cards NO expandidas */
  @media (hover: hover) {
    .profesor-card:hover:not(.expanded) {
      background: var(--foto-color) left top / cover no-repeat;
    }

    .profesor-card:hover:not(.expanded)::after,
    .profesor-card.expanded::after {
      background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, transparent 100%);
    }

    .profesor-card:hover:not(.expanded) .logo-empresa {
      opacity: 0;
    }

    .profesor-card:hover:not(.expanded) .profesor-info {
      opacity: 1;
      transform: translateY(0);
      top: auto;
      bottom: 16px;
      left: 0;
      right: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      text-align: center;
    }

    .profesor-card:hover:not(.expanded) .info-logo-left {
      display: none;
    }

    .profesor-card:hover:not(.expanded) .info-text-right {
      text-align: center;
    }
  }

  /* Card expandida */
  .profesor-card.expanded {
    flex: 2;
    height: clamp(160px, 16vw, 256px);
    border-radius: clamp(8px, 0.78vw, 13px);
    background: var(--foto-color) left top / cover no-repeat;
  }

  .profesor-card.expanded::after {
    border-radius: 0 0 clamp(8px, 0.78vw, 13px) clamp(8px, 0.78vw, 13px);
  }

  .profesor-card.expanded .logo-empresa {
    opacity: 0;
  }

  .profesor-card.expanded .profesor-info {
    opacity: 1;
    transform: translateY(0);
  }

  .profesor-card:focus-visible {
    outline: 3px solid #FFCD00;
    outline-offset: 3px;
  }

  /* Logo centrado abajo — estado default */
  .logo-empresa {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    text-align: center;
    transition: opacity 0.3s ease;
  }

  .logo-empresa img {
    max-width: 110px;
    max-height: 36px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    display: block;
  }

  .logo-empresa img[alt="Universidad de las Hespérides"] {
    width: 160px !important;
    max-width: none !important;
    max-height: none !important;
    height: auto !important;
    object-fit: contain !important;
    position: relative;
    top: 20px;
  }

  .info-logo[alt="Universidad de las Hespérides"] {
    max-width: 300px;
    max-height: 80px;
  }

  .logo-empresa img[alt="Kapital"] {
    filter: none;
    mix-blend-mode: normal;
  }

  .info-logo[alt="Kapital"] {
    filter: none;
    mix-blend-mode: normal;
  }

  /* Info — oculta por defecto, flex con logo izq y texto der */
  .profesor-info {
    position: absolute;
    bottom: 16px;
    left: 16px;
    right: 16px;
    z-index: 3;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
  }

  .info-logo-left {
    flex-shrink: 0;
  }

  .info-logo {
    max-width: 120px;
    max-height: 40px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    display: block;
  }

  .info-text-right {
    text-align: right;
    flex: 1;
  }

  .profesor-nombre {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(12px, 1.1vw, 18px);
    line-height: 1.2;
    color: #fff;
    margin: 0 0 2px;
    text-shadow: none;
  }

  .profesor-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: clamp(9px, 0.8vw, 13px);
    line-height: 1.3;
    color: #fff;
    margin: 0;
    text-shadow: none;
  }

  /* Flechas */
  .aprende-arrows {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 20px;
  }

  .aprende-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid #1a1a1a;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, opacity 0.2s;
    color: #1a1a1a;
  }

  .aprende-arrow:hover { background: rgba(0,0,0,0.05); }
  .aprende-arrow:disabled { opacity: 0.3; cursor: default; }

  /* Mobile */
  @media (max-width: 900px) {
    .aprende-section { padding-inline: 20px; overflow: visible; }

    .cards-container {
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 12px;
      padding-bottom: 10px;
      scrollbar-width: none;
      align-items: stretch;
    }

    .cards-container::-webkit-scrollbar { display: none; }

    .profesor-card,
    .profesor-card.visible {
      flex: 0 0 70vw;
      height: 280px;
      display: block;
      scroll-snap-align: start;
    }

    .profesor-card.expanded {
      flex: 0 0 70vw;
      height: 280px;
    }

    .profesor-card.expanded .profesor-info {
      display: flex;
      opacity: 1;
      transform: translateY(0);
    }

    /* Mobile: texto centrado, sin logo en info */
    .profesor-info {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .info-logo-left { display: none; }

    .info-text-right { text-align: center; }

    .profesor-card.expanded .profesor-nombre {
      font-size: 14px;
      font-weight: 600;
    }

    .profesor-card.expanded .profesor-cargo {
      font-size: 11px;
      font-weight: 300;
    }

    .logo-empresa { bottom: 12px; }
    .logo-empresa img { max-width: 120px; max-height: 44px; }
    .logo-empresa img[alt="Universidad de las Hespérides"] { width: 120px !important; }

    .aprende-arrows { display: flex; justify-content: center; gap: 16px; margin-top: 16px; }
  }
</style>

<script>
  const container = document.getElementById("cards-container") as HTMLElement;
  const allCards = Array.from(container?.querySelectorAll<HTMLElement>(".profesor-card") || []);
  const prevBtn = document.getElementById("aprende-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("aprende-next") as HTMLButtonElement;
  const VISIBLE = 6;
  let startIndex = 0;
  const isMobile = window.innerWidth <= 900;

  function renderVisible() {
    if (isMobile) {
      allCards.forEach(card => card.classList.add("visible"));
      return;
    }
    allCards.forEach((card, i) => {
      if (i >= startIndex && i < startIndex + VISIBLE) {
        card.classList.add("visible");
        card.style.display = "";
      } else {
        card.classList.remove("visible");
        card.classList.remove("expanded");
        card.style.display = "none";
      }
    });
    if (prevBtn) prevBtn.disabled = startIndex === 0;
    if (nextBtn) nextBtn.disabled = startIndex + VISIBLE >= allCards.length;
  }

  // Click handler
  allCards.forEach(card => {
    card.addEventListener("click", () => {
      if (window.innerWidth <= 900) {
        // Mobile: toggle
        const wasExpanded = card.classList.contains("expanded");
        allCards.forEach(c => c.classList.remove("expanded"));
        if (!wasExpanded) card.classList.add("expanded");
        return;
      }
      // Desktop: siempre una expandida
      if (!card.classList.contains("expanded")) {
        allCards.forEach(c => c.classList.remove("expanded"));
        card.classList.add("expanded");
      }
    });

    card.addEventListener("keydown", (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === "Enter" || ke.key === " ") {
        ke.preventDefault();
        if (window.innerWidth <= 900) {
          const wasExpanded = card.classList.contains("expanded");
          allCards.forEach(c => c.classList.remove("expanded"));
          if (!wasExpanded) card.classList.add("expanded");
          return;
        }
        if (!card.classList.contains("expanded")) {
          allCards.forEach(c => c.classList.remove("expanded"));
          card.classList.add("expanded");
        }
      }
    });
  });

  // Flechas desktop
  prevBtn?.addEventListener("click", () => {
    if (isMobile) return;
    if (startIndex > 0) { startIndex--; renderVisible(); }
  });
  nextBtn?.addEventListener("click", () => {
    if (isMobile) return;
    if (startIndex + VISIBLE < allCards.length) { startIndex++; renderVisible(); }
  });

  // Flechas mobile — scroll
  if (isMobile && container) {
    const scrollAmt = () => (allCards[0]?.offsetWidth || 250) + 12;
    prevBtn?.addEventListener("click", () => container.scrollBy({ left: -scrollAmt(), behavior: "smooth" }));
    nextBtn?.addEventListener("click", () => container.scrollBy({ left: scrollAmt(), behavior: "smooth" }));
  }

  renderVisible();

  // Init desktop — primera card expandida
  if (!isMobile && allCards.length > 0) {
    allCards[0].classList.add("expanded");
  }
</script>
