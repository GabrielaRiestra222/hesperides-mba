---
// AprendeMejores.astro
const profesores = [
  { id: 1,  nombre: "Miguel Anxo Bastos",    cargo: "Profesor visitante - Universidad de las Hespérides", foto: "/img/aprende/allo/miguel-anxo-bastos.jpg",    fotoColor: "/img/aprende/color/miguel-anxo-bastos.jpg",    logo: "",                                     logoAlt: "h." },
  { id: 2,  nombre: "Joan Tubau",             cargo: "Fundador - Podcast Kapital",                         foto: "/img/aprende/allo/joan-tubau.jpg",             fotoColor: "/img/aprende/color/joan-tubau.jpg",             logo: "",        logoAlt: "Kapital" },
  { id: 3,  nombre: "Marc Urgell",            cargo: "CEO - Abast Global",                                 foto: "/img/aprende/allo/marc-urgell.jpg",            fotoColor: "/img/aprende/color/marc-urgell.jpg",            logo: "/img/aprende/logos/abast.png",          logoAlt: "Abast" },
  { id: 4,  nombre: "Gerard Caelles",         cargo: "CBO - SpliceBio",                                    foto: "/img/aprende/allo/gerard-caelles.jpg",         fotoColor: "/img/aprende/color/gerard-caelles.jpg",         logo: "/img/aprende/logos/splicebio.png",      logoAlt: "SpliceBio" },
  { id: 5,  nombre: "Lourdes Fuster",         cargo: "Global Head of CRM and Product Marketing - Wallapop",foto: "/img/aprende/allo/lourdes-fuster.jpg",         fotoColor: "/img/aprende/color/lourdes-fuster.jpg",         logo: "/img/aprende/logos/wallapop.png",       logoAlt: "Wallapop" },
  { id: 6,  nombre: "Joan Cortadellas",       cargo: "Marketing Director - Trenes.com",                    foto: "/img/aprende/allo/joan-cortadellas.jpg",       fotoColor: "/img/aprende/color/joan-cortadellas.jpg",       logo: "/img/aprende/logos/trenes.png",         logoAlt: "Trenes.com" },
  { id: 7,  nombre: "José Juan González",     cargo: "CEO - Canaragua",                                    foto: "/img/aprende/allo/jose-juan-gonzalez.jpg",     fotoColor: "/img/aprende/color/jose-juan-gonzalez.jpg",     logo: "/img/aprende/logos/canaragua.png",      logoAlt: "Canaragua" },
  { id: 8,  nombre: "Oliver Alonso",          cargo: "Presidente - Domingo Alonso Group",                  foto: "/img/aprende/allo/oliver-alonso.jpg",          fotoColor: "/img/aprende/color/oliver-alonso.jpg",          logo: "",                                     logoAlt: "Alonso group" },
  { id: 9,  nombre: "Sebastián Cerezo",       cargo: "Socio - Moira Capital Partners",                     foto: "/img/aprende/allo/sebastian-cerezo.jpg",       fotoColor: "/img/aprende/color/sebastian-cerezo.jpg",       logo: "/img/aprende/logos/moira.png",          logoAlt: "Moira" },
  { id: 10, nombre: "José Martínez",          cargo: "CEO - Grupo Martínez Abolafio",                      foto: "/img/aprende/allo/jose-martinez.jpg",          fotoColor: "/img/aprende/color/jose-martinez.jpg",          logo: "/img/aprende/logos/grupo-martinez.png", logoAlt: "Grupo Martínez" },
  { id: 11, nombre: "Martín Eugenio Pérez",   cargo: "Presidente - Aloe Lanzarote Plus",                   foto: "/img/aprende/allo/martin-eugenio-perez.jpg",   fotoColor: "/img/aprende/color/martin-eugenio-perez.jpg",   logo: "/img/aprende/logos/aloe-plus.png",      logoAlt: "Aloe Plus" },
  { id: 12, nombre: "José Julio Artiles",     cargo: "CEO - Satocan",                                      foto: "/img/aprende/allo/jose-julio-artiles.jpg",     fotoColor: "/img/aprende/color/jose-julio-artiles.jpg",     logo: "/img/aprende/logos/satocan.png",        logoAlt: "Satocan" },
];
---

<section class="aprende-section">
  <div class="aprende-header">
    <h2 class="aprende-titulo">
      <span class="titulo-bold">Aprende </span><span class="titulo-normal">de los mejores</span>
    </h2>
  </div>

  <div class="cards-container" id="cards-container">
    {profesores.map((profesor) => (
      <div
        class="profesor-card"
        data-id={profesor.id}
        style={`--foto: url('${profesor.foto}'); --foto-color: url('${profesor.fotoColor}')`}
        role="button"
        tabindex="0"
        aria-label={`Ver perfil de ${profesor.nombre}`}
      >
        <!-- overlay amarillo BN -->
        <div class="foto-overlay"></div>

        <!-- logo empresa (solo si existe) -->
        {profesor.logo && (
          <div class="logo-empresa">
            <img src={profesor.logo} alt={profesor.logoAlt} />
          </div>
        )}

        <!-- info expandido -->
        <div class="profesor-info">
          <p class="profesor-nombre">{profesor.nombre}</p>
          <p class="profesor-cargo">{profesor.cargo}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .aprende-section {
    width: 100%;
    background: #fff;
    padding: clamp(29px, 3.64vw, 72px) 0 clamp(34px, 4.25vw, 84px);
    padding-inline: 0;
    overflow: hidden;
  }

  /* ── Título ── */
  .aprende-header {
    text-align: center;
    margin-bottom: clamp(21px, 2.43vw, 48px);
  }

  .aprende-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 400;
    margin: 0;
    line-height: 1.2;
  }

  .titulo-bold   { color: #FFCD00; font-weight: 700; }
  .titulo-normal { color: #FFCD00; font-weight: 400; }

  /* ── Cards container ── */
  .cards-container {
    display: flex;
    flex-direction: row;
    gap: 0.625rem;
    align-items: stretch;
    padding: 0;
    box-sizing: border-box;
    width: 100%;
    margin-inline: 0;
    padding-inline: 0;
  }

  /* ── Card base ── */
  .profesor-card {
    position: relative;
    flex: 1;
    min-width: 0;
    height: 300px;
    border-radius: 15px;
    overflow: hidden;
    cursor: pointer;
    background: var(--foto) lightgray center / cover no-repeat;
    filter: none;
    transition:
      flex 0.55s cubic-bezier(0.4, 0, 0.2, 1),
      filter 0.45s ease;
  }

  /* Expandida — en color */
  .profesor-card.expanded {
    flex: 3.5;
    filter: grayscale(0%);
    background: var(--foto-color) lightgray center / cover no-repeat;
  }

  .profesor-card:focus-visible {
    outline: 3px solid #FFCD00;
    outline-offset: 3px;
  }

  /* ── Overlay amarillo (solo contraído) ── */
  .foto-overlay { display: none; }

  /* ── Logo empresa ── */
  .logo-empresa {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .logo-empresa img {
    max-width: 110px;
    max-height: 36px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .profesor-card.expanded .logo-empresa {
    opacity: 0;
    transform: translateX(-50%) translateY(8px);
    pointer-events: none;
  }

  /* ── Info (solo expandido) ── */
  .profesor-info {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    z-index: 3;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease 0.15s, transform 0.3s ease 0.15s;
    pointer-events: none;
  }

  .profesor-card.expanded .profesor-info {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .profesor-nombre {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(13px, 1.52vw, 30px);
    line-height: 1.2;
    color: #fff;
    margin: 0 0 clamp(4px, 0.45vw, 9px);
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  .profesor-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: clamp(11px, 1.21vw, 24px);
    line-height: 1.3;
    color: #fff;
    margin: 0;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  /* ── Responsive ── */
  @media (min-width: 901px) {
    .profesor-card { min-height: clamp(280px, 22vw, 380px); height: auto; }
  }

  @media (max-width: 900px) {
    .aprende-section { padding-inline: 20px; }
    .cards-container { flex-wrap: wrap; }
    .profesor-card, .profesor-card.expanded {
      flex: 0 0 calc(33.333% - 8px);
      height: 220px;
    }
  }

  @media (max-width: 600px) {
    .profesor-card, .profesor-card.expanded {
      flex: 0 0 calc(50% - 6px);
      height: 200px;
    }
  }
</style>

<script>
  const container = document.getElementById("cards-container");
  const cards = container?.querySelectorAll(".profesor-card");

  function expandCard(card: Element) {
    cards?.forEach((c) => c.classList.remove("expanded"));
    card.classList.add("expanded");
  }

  function collapseAll() {
    cards?.forEach((c) => c.classList.remove("expanded"));
  }

  cards?.forEach((card) => {
    card.addEventListener("click", () => {
      card.classList.contains("expanded") ? collapseAll() : expandCard(card);
    });
    card.addEventListener("keydown", (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === "Enter" || ke.key === " ") {
        ke.preventDefault();
        card.classList.contains("expanded") ? collapseAll() : expandCard(card);
      }
    });
  });
</script>
