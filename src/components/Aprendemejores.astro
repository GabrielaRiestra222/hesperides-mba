---
// AprendeMejores.astro
const profesores = [
  { id: 1, nombre: "Manuel de la Rosa",  cargo: "CEO Bankinter Internacional",  logo: "/img/Bankinter-768x136.png",          logoAlt: "Bankinter" },
  { id: 2, nombre: "Ana García",         cargo: "CEO & Founder Caetsu Two",      logo: "/img/aier-logo-card___1__bk.png",    logoAlt: "AIER"      },
  { id: 3, nombre: "Pedro Martínez",     cargo: "Director General Binter",       logo: "/img/BinterJPG_BK.png",              logoAlt: "Binter"    },
  { id: 4, nombre: "Laura Sánchez",      cargo: "CFO HallFrencia",               logo: "/img/Human_Rights_Foundation_bk.png",logoAlt: "HRF"       },
  { id: 5, nombre: "Carlos López",       cargo: "Partner Globera",               logo: "/img/LHR_LG_NEGRO-1024x749.png",     logoAlt: "Lopesan"   },
  { id: 6, nombre: "Isabel Ruiz",        cargo: "Senior Manager Newlink",        logo: "/img/Newlink-logo-bk.png",           logoAlt: "Newlink"   },
];

const PLACEHOLDER = "/img/b5e11c54ee1b173c3512ee9a6b53fe00e88c3af6.jpg";
---

<section class="aprende-section">
  <div class="aprende-header">
    <h2 class="aprende-titulo">
      <span class="titulo-bold">Aprende </span><span class="titulo-normal">de los mejores</span>
    </h2>
  </div>

  <div class="cards-container" id="cards-container">
    {profesores.map((profesor) => (
      <div
        class="profesor-card"
        data-id={profesor.id}
        style={`--foto: url('${PLACEHOLDER}')`}
        role="button"
        tabindex="0"
        aria-label={`Ver perfil de ${profesor.nombre}`}
      >
        <!-- overlay amarillo BN -->
        <div class="foto-overlay"></div>

        <!-- logo empresa -->
        <div class="logo-empresa">
          <img src={profesor.logo} alt={profesor.logoAlt} />
        </div>

        <!-- info expandido -->
        <div class="profesor-info">
          <p class="profesor-nombre">{profesor.nombre}</p>
          <p class="profesor-cargo">{profesor.cargo}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .aprende-section {
    width: 100%;
    background: #fff;
    padding: 48px 0 56px;
    overflow: hidden;
  }

  /* ── Título ── */
  .aprende-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .aprende-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 400;
    margin: 0;
    line-height: 1.2;
  }

  .titulo-bold   { color: #FFCD00; font-weight: 700; }
  .titulo-normal { color: #FFCD00; font-weight: 400; }

  /* ── Cards container ── */
  .cards-container {
    display: flex;
    flex-direction: row;
    gap: 10px;
    align-items: stretch;
    padding: 0 clamp(16px, 3vw, 56px);
    box-sizing: border-box;
    width: 100%;
    padding-left: 2vw;
    padding-right: 2vw;

  }

  /* ── Card base — Figma: 270×300px, background con offset exacto ── */
  .profesor-card {
    position: relative;
    flex: 1;
    min-width: 0;
    height: 300px;
    border-radius: 15px;
    overflow: hidden;
    cursor: pointer;

    /* Background con specs del Figma */
    background: var(--foto) lightgray -25.709px -18.944px / 130.952% 141% no-repeat;
    filter: grayscale(100%);

    transition:
      flex 0.55s cubic-bezier(0.4, 0, 0.2, 1),
      filter 0.45s ease;
  }

  /* Expandida — horizontal, en color */
  .profesor-card.expanded {
    flex: 3.5;
    filter: grayscale(0%);
    /* En expandido la imagen se ve normal, centrada */
    background: var(--foto) lightgray center / cover no-repeat;
  }

  .profesor-card:focus-visible {
    outline: 3px solid #FFCD00;
    outline-offset: 3px;
  }

  /* ── Overlay amarillo (solo contraído) ── */
  .foto-overlay {
    position: absolute;
    inset: 0;
    background: rgba(255, 205, 0, 0.52);
    mix-blend-mode: multiply;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.35s ease;
    border-radius: 15px;
  }

  .profesor-card.expanded .foto-overlay { opacity: 0; }

  /* ── Logo empresa ── */
  .logo-empresa {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .logo-empresa img {
    max-width: 110px;
    max-height: 36px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .profesor-card.expanded .logo-empresa {
    opacity: 0;
    transform: translateX(-50%) translateY(8px);
    pointer-events: none;
  }

  /* ── Info (solo expandido) ── */
  .profesor-info {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    z-index: 3;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease 0.15s, transform 0.3s ease 0.15s;
    pointer-events: none;
  }

  .profesor-card.expanded .profesor-info {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .profesor-nombre {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
    color: #fff;
    margin: 0 0 6px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  .profesor-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: 16px;
    line-height: 1.3;
    color: #fff;
    margin: 0;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .cards-container { flex-wrap: wrap; }
    .profesor-card, .profesor-card.expanded {
      flex: 0 0 calc(33.333% - 8px);
      height: 220px;
    }
  }

  @media (max-width: 600px) {
    .profesor-card, .profesor-card.expanded {
      flex: 0 0 calc(50% - 6px);
      height: 200px;
    }
  }
</style>

<script>
  const container = document.getElementById("cards-container");
  const cards = container?.querySelectorAll(".profesor-card");

  function expandCard(card: Element) {
    cards?.forEach((c) => c.classList.remove("expanded"));
    card.classList.add("expanded");
  }

  function collapseAll() {
    cards?.forEach((c) => c.classList.remove("expanded"));
  }

  cards?.forEach((card) => {
    card.addEventListener("click", () => {
      card.classList.contains("expanded") ? collapseAll() : expandCard(card);
    });
    card.addEventListener("keydown", (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === "Enter" || ke.key === " ") {
        ke.preventDefault();
        card.classList.contains("expanded") ? collapseAll() : expandCard(card);
      }
    });
  });
</script>