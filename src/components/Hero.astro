  /* -------------------------
     FORM COUNTRY INIT
  -------------------------*/

  function initFormCountries(form) {
    const paisSelect    = form.querySelector('select[name="pais"]')
    const provWrap      = form.querySelector('[name="provincia"]')?.closest('.select-wrap')
    const prefijoSelect = form.querySelector('select[name="prefijo"]')
    if (!paisSelect) return

    // Populate country select
    COUNTRIES.forEach(c => {
      const opt = document.createElement("option")
      opt.value = c.name
      opt.textContent = c.name
      paisSelect.appendChild(opt)
    })

    // Populate prefijo with all unique prefixes
    if (prefijoSelect) {
      UNIQUE_PREFIXES.forEach(p => {
        const opt = document.createElement("option")
        opt.value = p
        opt.textContent = p
        prefijoSelect.appendChild(opt)
      })
    }

    function setHasValue(el) {
      const pf = el.closest(".form-field")
      if (pf) pf.classList.toggle("has-value", !!el.value)
    }

    function updateProvincia(countryName) {
      if (!provWrap) return
      const country = COUNTRIES.find(c => c.name === countryName)
      const currentEl = provWrap.querySelector('[name="provincia"]')
      const arrow = provWrap.querySelector('.select-arrow')

      if (country && country.provinces.length > 0) {
        // Ensure it's a select
        let sel = currentEl
        if (currentEl && currentEl.tagName === 'INPUT') {
          sel = document.createElement("select")
          sel.name = "provincia"
          sel.required = true
          currentEl.replaceWith(sel)
        }
        if (sel) {
          sel.innerHTML = '<option value="" disabled selected hidden></option>'
          country.provinces.forEach(p => {
            const opt = document.createElement("option")
            opt.value = p
            opt.textContent = p
            sel.appendChild(opt)
          })
          sel.addEventListener("input",  () => setHasValue(sel))
          sel.addEventListener("change", () => setHasValue(sel))
          setHasValue(sel)
        }
        if (arrow) arrow.style.display = ""
      } else {
        // Replace with free-text input
        if (currentEl && currentEl.tagName === 'SELECT') {
          const inp = document.createElement("input")
          inp.type = "text"
          inp.name = "provincia"
          inp.required = true
          currentEl.replaceWith(inp)
          inp.addEventListener("input",  () => setHasValue(inp))
          inp.addEventListener("change", () => setHasValue(inp))
          inp.addEventListener("blur",   () => setHasValue(inp))
        }
        if (arrow) arrow.style.display = "none"
        const inp = provWrap.querySelector('input[name="provincia"]')
        if (inp) setHasValue(inp)
      }
    }

    function updatePrefijo(countryName) {
      if (!prefijoSelect) return
      const country = COUNTRIES.find(c => c.name === countryName)
      if (country) {
        prefijoSelect.value = country.prefix
        setHasValue(prefijoSelect)
      }
    }

    paisSelect.addEventListener("change", () => {
      updateProvincia(paisSelect.value)
      updatePrefijo(paisSelect.value)
      setHasValue(paisSelect)
    })

    // Track has-value on all fields
    form.querySelectorAll("input:not([type='checkbox']), select").forEach(el => {
      el.addEventListener("input",  () => setHasValue(el))
      el.addEventListener("change", () => setHasValue(el))
      el.addEventListener("blur",   () => setHasValue(el))
    })

    // Autofill detection
    setTimeout(() => {
      form.querySelectorAll("input:not([type='checkbox']), select").forEach(el => setHasValue(el))
    }, 500)
  }

