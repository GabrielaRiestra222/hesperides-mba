---
// Hero.astro
const {
  tag = "MÁSTER UNIVERSITARIO\nEN ADMINISTRACIÓN Y\nDIRECCIÓN DE EMPRESAS (MBA ONLINE)",
  title = "Hay muchos MBA,\npero no son como este.",
} = Astro.props;
---

<section class="hero">

  <!-- Background image -->
  <img src="/img/hero-bg.jpg" alt="" class="hero-bg" />

  <!-- Dark overlay -->
  <div class="hero-overlay"></div>

  <!-- Contenido -->
  <div class="hero-content">

    <!-- LEFT -->
    <div class="hero-left">
      <span class="hero-tag">{tag}</span>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-description"><span class="hero-desc-first">El único MBA donde tu proyecto es el eje de todo.</span>Formación exigente y orientada a resultados reales. Incluye un bloque diferencial en <strong>IA aplicada a la empresa</strong>, con el que<br/>pasarás de <strong>operar herramientas, a diseñar sistemas que ejecutan por ti.</strong></p>
      <div class="hero-pricing">
        <p class="hero-pricing-beca">Programa con Beca del 80%</p>
        <p class="hero-pricing-old"><span>5.765 €</span></p>
        <p class="hero-pricing-desde">Desde</p>
        <p class="hero-pricing-new">1.275 €</p>
      </div>
      <!-- CTAs visibles solo en móvil/vertical -->
      <div class="hero-buttons">
        <button class="hero-cta-btn" id="hero-open-modal">CONTACTA ASESOR</button>
      </div>
    </div>

    <!-- RIGHT — tarjeta amarilla con formulario (desktop) -->
    <div class="hero-right">
      <div class="hero-card">
        <div class="hero-card-photo">
          <img src="/img/Rallo_fondo.jpg" alt="Director MBA" />
          <button class="hero-card-play" aria-label="Reproducir vídeo" id="hero-play-btn"></button>
          <div class="hero-video-container" id="hero-video-container" style="display:none;">
            <iframe
              id="hero-vimeo-iframe"
              src=""
              allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              style="position:absolute;top:0;left:0;width:100%;height:100%;border-radius:inherit;border:none;"
              title="Video MBA">
            </iframe>
          </div>
        </div>
        <div class="hero-form-wrap">
          <p class="hero-form-title">CONTACTA CON UN ASESOR ACADÉMICO</p>
          <form class="hero-form" id="mba-form-desktop">
            <div class="form-row">
              <div class="form-field">
                <label class="form-label">Nombre</label>
                <input type="text" name="nombre" required />
              </div>
              <div class="form-field">
                <label class="form-label">Apellidos</label>
                <input type="text" name="apellidos" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field form-field--select">
                <label class="form-label">País</label>
                <div class="select-wrap">
                  <select name="pais" required>
                    <option value="" disabled selected hidden></option>
                  </select>
                  <svg class="select-arrow" width="10" height="6" viewBox="0 0 10 6"><path d="M5 6L0 0h10L5 6z" fill="currentColor"/></svg>
                </div>
              </div>
              <div class="form-field form-field--select">
                <label class="form-label">Provincia</label>
                <div class="select-wrap">
                  <select name="provincia" required>
                    <option value="" disabled selected hidden></option>
                  </select>
                  <svg class="select-arrow" width="10" height="6" viewBox="0 0 10 6"><path d="M5 6L0 0h10L5 6z" fill="currentColor"/></svg>
                </div>
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label class="form-label">Correo electrónico</label>
                <input type="email" name="email" required />
              </div>
              <div class="form-field form-field--phone">
                <div class="phone-group">
                  <div class="form-field form-field--prefix">
                    <label class="form-label">Prefijo</label>
                    <div class="select-wrap select-wrap--prefix">
                      <select name="prefijo">
                        <option value="" disabled selected hidden></option>
                      </select>
                      <svg class="select-arrow" width="10" height="6" viewBox="0 0 10 6"><path d="M5 6L0 0h10L5 6z" fill="currentColor"/></svg>
                    </div>
                  </div>
                  <div class="form-field form-field--tel">
                    <label class="form-label">Teléfono</label>
                    <input type="tel" name="telefono" required />
                  </div>
                </div>
              </div>
            </div>
            <div class="form-footer">
              <label class="form-legal">
                <input type="checkbox" name="acepta" required />
                <span>Acepto el <a href="https://hesperides.edu.es/aviso-legal/">aviso legal</a> y la <a href="https://hesperides.edu.es/politica-de-privacidad/">política de privacidad</a></span>
              </label>
              <button type="submit" class="form-submit">ENVIAR SOLICITUD</button>
            </div>
          </form>
        </div>
      </div>
    </div>

  </div>

  <!-- Modal formulario — solo formulario, sin foto -->
  <div class="hero-modal-overlay" id="hero-modal" aria-hidden="true">
    <div class="hero-modal-card">
      <button class="hero-modal-close" id="hero-close-modal" aria-label="Cerrar">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="hero-form-wrap">
        <p class="hero-form-title">CONTACTA CON UN ASESOR ACADÉMICO</p>
        <form class="hero-form" id="mba-form-modal">
          <div class="form-row">
            <div class="form-field">
              <label class="form-label">Nombre</label>
              <input type="text" name="nombre" required />
            </div>
            <div class="form-field">
              <label class="form-label">Apellidos</label>
              <input type="text" name="apellidos" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-field form-field--select">
              <label class="form-label">País</label>
              <div class="select-wrap">
                <select name="pais" required>
                  <option value="" disabled selected hidden></option>
                </select>
                <svg class="select-arrow" width="10" height="6" viewBox="0 0 10 6"><path d="M5 6L0 0h10L5 6z" fill="currentColor"/></svg>
              </div>
            </div>
            <div class="form-field form-field--select">
              <label class="form-label">Provincia</label>
              <div class="select-wrap">
                <select name="provincia" required>
                  <option value="" disabled selected hidden></option>
                </select>
                <svg class="select-arrow" width="10" height="6" viewBox="0 0 10 6"><path d="M5 6L0 0h10L5 6z" fill="currentColor"/></svg>
              </div>
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label class="form-label">Correo electrónico</label>
              <input type="email" name="email" required />
            </div>
            <div class="form-field form-field--phone">
              <div class="phone-group">
                <div class="form-field form-field--prefix">
                  <label class="form-label">Prefijo</label>
                  <div class="select-wrap select-wrap--prefix">
                    <select name="prefijo">
                      <option value="" disabled selected hidden></option>
                    </select>
                    <svg class="select-arrow" width="10" height="6" viewBox="0 0 10 6"><path d="M5 6L0 0h10L5 6z" fill="currentColor"/></svg>
                  </div>
                </div>
                <div class="form-field form-field--tel">
                  <label class="form-label">Teléfono</label>
                  <input type="tel" name="telefono" required />
                </div>
              </div>
            </div>
          </div>
          <div class="form-footer">
            <label class="form-legal">
              <input type="checkbox" name="acepta" required />
              <span>Acepto el <a href="https://hesperides.edu.es/aviso-legal/">aviso legal</a> y la <a href="https://hesperides.edu.es/politica-de-privacidad/">política de privacidad</a></span>
            </label>
            <button type="submit" class="form-submit">ENVIAR SOLICITUD</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="hero-info-marquee">
    <div class="hero-marquee-track">
      <div class="hero-marquee-item"><img src="/img/iconoir_graduation-cap.svg" alt="" /><span>Universitario</span></div>
      <div class="hero-marquee-item"><img src="/img/iconoir_calendar.svg" alt="" /><span>Inicio Abril 2026</span></div>
      <div class="hero-marquee-item"><img src="/img/iconoir_alarm.svg" alt="" /><span>1 año</span></div>
      <div class="hero-marquee-item"><img src="/img/iconoir_modern-tv.svg" alt="" /><span>100% online</span></div>
      <div class="hero-marquee-item"><img src="/img/iconoir_euro-square.svg" alt="" /><span>Desde 1.275 €</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_graduation-cap.svg" alt="" /><span>Universitario</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_calendar.svg" alt="" /><span>Inicio Abril 2026</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_alarm.svg" alt="" /><span>1 año</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_modern-tv.svg" alt="" /><span>100% online</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_euro-square.svg" alt="" /><span>Desde 1.275 €</span></div>
    </div>
  </div>

</section>

<!-- Banda nav desktop -->
<div class="hero-bottom-menu">
  <div class="hero-bottom-inner">
    <a href="#descripcion">Descripción</a>
    <a href="#programa">Programa</a>
    <a href="#profesores">Profesores</a>
    <a href="#metodologia">Metodología</a>
    <a href="#pagos">Inscripción</a>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+HK:wght@200;300;400;500;700&display=swap');

  /* ── Hero ── */
  .hero {
    position: relative;
    width: 100%;
    min-height: 910px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding-inline: clamp(20px, 6.77vw, 130px);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: none;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  /* ── Contenido principal ── */
  .hero-content {
    position: relative;
    z-index: 2;
    flex: 1;
    width: min(1285px, 100%);
    margin-inline: auto;
    box-sizing: border-box;
    padding-block: clamp(40px, 5vw, 80px) 80px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(32px, 4vw, 80px);
    align-items: center;
  }

  /* ── LEFT ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;

  }

  /* Tag amarillo */
  .hero-tag {
    display: block;
    color: #FFCD00;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: clamp(21px, 2.43vw, 48px);
    line-height: 30px;
    letter-spacing: 0.96px;
    text-transform: uppercase;
    white-space: pre-line;
    margin: 0;
  }

  /* Título */
  .hero-title {
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(38px, 4.85vw, 96px);
    line-height: 59px;
    letter-spacing: -1.28px;
    white-space: pre-line;
    margin: 0;
  }

  /* Descripción */
  .hero-description {
    max-width: 530px;
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: clamp(13px, 1.52vw, 30px);
    line-height: 28px;
    letter-spacing: 1px;
    margin-bottom: 0;
    gap: 100px;
    opacity: 0.95;
  }

  .hero-desc-first {
    display: block;
    margin-bottom: clamp(8px, 0.8vw, 14px);
  }

  .hero-description strong {
    font-weight: 500;
    color: #fff;
  }
  .hero-description br {
    content: "";
    display: block;
    margin-bottom: 100px; 
  }

  .hero-pricing {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 8px;
  }

  .hero-pricing-beca {
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(12px, 1.1vw, 18px);
    line-height: 1.3;
    margin: 0;
  }

  .hero-pricing-old {
    margin: 0;
    margin-bottom: clamp(6px, 0.6vw, 12px);
  }

  .hero-pricing-old span {
    color: #999;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(26px, 2.6vw, 46px);
    text-decoration: line-through;
    text-decoration-color: #FFCD00;
    text-decoration-thickness: 2px;
    line-height: 1.2;
  }

  .hero-pricing-desde {
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(12px, 1vw, 16px);
    margin: 4px 0 0 0;
    line-height: 1;
  }

  .hero-pricing-new {
    color: #FFCD00;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(26px, 2.6vw, 46px);
    line-height: 1.1;
    margin: 0;
  }

  /* Botones */
  .hero-buttons {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  /* ── RIGHT — tarjeta amarilla ── */
  .hero-right {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    flex-shrink: 0;
    margin-bottom: clamp(20px, 2.27vw, 45px);
  }

  .hero-card {
    position: relative;
    width: 440px;
    border-radius: 29.896px;
    background: #FFCD00;
    box-shadow: 0 7.972px 6.976px 4.983px rgba(0, 0, 0, 0.25);
    overflow: visible;
  }

  /* Foto encima de la tarjeta */
  .hero-card-photo {
    position: relative;
    width: 100%;
    height: 235px;
    border-radius: 29.896px;
    overflow: hidden;
    background: lightgray center top / cover no-repeat;
    background-image: url('/img/Rallo_fondo.jpg');
    background-position: center top;
    background-size: cover;
  }

  .hero-card-photo img {
    display: none;
    width: 500px;
    height: 180px;

  }

  .hero-card-play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: fit-content;
    height: fit-content;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    opacity: 0.45;
    transition: opacity 0.2s ease;
  }

  .hero-card-play:hover {
    opacity: 0.7;
  }

  .hero-card-play::after {
    content: '';
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 18px 0 18px 32px;
    border-color: transparent transparent transparent #FFCD00;
  }

  .hero-video-container {
    position: absolute;
    inset: 0;
    z-index: 5;
    background: #000;
    border-radius: inherit;
  }

  /* Formulario */
  .hero-form-wrap {
    padding: clamp(16px, 1.82vw, 36px) clamp(18px, 2.12vw, 42px) clamp(18px, 2.12vw, 42px) clamp(25px, 2.88vw, 57px);
  }

  .hero-form-title {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(13px, 1.52vw, 30px);
    line-height: normal;
    letter-spacing: 0.2px;
    color: #1a1a1a;
    margin: 0 0 clamp(11px, 1.21vw, 24px);
  }

  .hero-form {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
  }
  

  .hero-form input[type="text"],
  .hero-form input[type="email"],
  .hero-form input[type="tel"] {
    width: 100%;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.847);
    border-radius: 999px;
    background: #ffcd00;
    padding: 0 clamp(8px, 0.91vw, 18px);
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(8px, 0.91vw, 18px);
    font-weight: 500;
    color: #1a1a1a;
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.2s;
    box-shadow: 0.8px 0 1.5px 0 rgba(0, 0, 0, 0.12);

  }

  .hero-form input::placeholder {
    color: #1a1a1a;
    font-size: clamp(11px, 1.21vw, 24px);
    font-weight: 400;
  }

  .hero-form input:focus { border-color: rgba(0,0,0,0.3); outline: none; }

  .hero-form input:-webkit-autofill,
  .hero-form input:-webkit-autofill:hover,
  .hero-form input:-webkit-autofill:focus,
  .hero-form select:-webkit-autofill,
  .hero-form select:-webkit-autofill:hover,
  .hero-form select:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px #ffcd00 inset !important;
    -webkit-text-fill-color: #1a1a1a !important;
    background-color: #ffcd00 !important;
    transition: background-color 5000s ease-in-out 0s;
  }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: clamp(3px, 0.30vw, 6px);
  }

  .form-legal {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(8px, 0.83vw, 17px);
    font-weight: 400;
    color: #1a1a1a;
    line-height: 1.4;
    cursor: pointer;
  }

  .form-legal input[type="checkbox"] {
    flex-shrink: 0;
    appearance: none;
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1.5px solid #fffdfd;
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: background 0.2s;
  }

  .form-legal input[type="checkbox"]:checked {
    background: #1a1a1a;
  }

  .form-legal input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 2px;
    width: 5px;
    height: 8px;
    border: 2px solid #FFCD00;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }

  .form-legal a {
    color: #1a1a1a;
    text-decoration: underline;
  }

  .form-submit {
    flex-shrink: 0;
    background: #1a1a1a;
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: clamp(8px, 0.83vw, 17px);
    letter-spacing: 0.06em;
    padding: clamp(7px, 0.76vw, 15px) clamp(13px, 1.52vw, 30px);
    border-radius: 999px;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
  }

  .form-submit:hover {
    background: #333;
  }

  /* ── Form fields with labels ── */
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  .form-label {
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(8px, 0.75vw, 12px);
    font-weight: 300;
    color: #1a1a1a;
    margin-bottom: 2px;
    padding-left: clamp(8px, 0.91vw, 18px);
    transition: color 0.2s;
  }

  .form-field.has-value .form-label,
  .form-field:focus-within .form-label {
    color: #888;
  }

  .form-field--prefix.has-value .form-label,
  .form-field--prefix:focus-within .form-label,
  .form-field--tel.has-value .form-label,
  .form-field--tel:focus-within .form-label {
    color: #888;
  }

  /* Select — matches input look */
  .hero-form select {
    width: 100%;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.847);
    border-radius: 999px;
    background: #ffcd00;
    padding: 0 28px 0 clamp(8px, 0.91vw, 18px);
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(8px, 0.91vw, 18px);
    font-weight: 500;
    color: #1a1a1a;
    box-sizing: border-box;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    transition: border-color 0.2s;
    box-shadow: 0.8px 0 1.5px 0 rgba(0, 0, 0, 0.12);
  }

  .hero-form select:focus { border-color: rgba(0,0,0,0.3); outline: none; }

  .select-wrap {
    position: relative;
    width: 100%;
  }

  .select-arrow {
    position: absolute;
    right: clamp(8px, 0.91vw, 18px);
    top: 55%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #000;
  }

  /* Phone group */
  .form-field--phone { flex: 1; }
  .phone-group {
    display: flex;
    gap: clamp(4px, 0.4vw, 8px);
    align-items: flex-end;
  }
  .form-field--prefix { flex: 0 0 auto; width: clamp(60px, 5.5vw, 90px); }
  .form-field--tel { flex: 1; }

  /* ── Info marquee (mobile only) — oculto en desktop ── */
  .hero-info-marquee { display: none; }

  /* ── Bottom menu ── */
  .hero-bottom-menu {
    position: relative;
    z-index: 100;
    width: 100%;
    height: 48px;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(7.5px);
    display: flex;
    align-items: center;
  }

  .hero-bottom-inner {
    width: 100%;
    box-sizing: border-box;
    padding: 0 clamp(20px, 6.77vw, 130px);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: clamp(20px, 2.5vw, 48px);
  }

  .hero-bottom-inner a {
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(9px, 0.99vw, 20px);
    font-weight: 300;
    color: #fff;
    text-decoration: none;
    opacity: 0.85;
