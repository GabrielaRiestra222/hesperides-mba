---
// Hero.astro
const {
  tag = "MÁSTER EN\nADMINISTRACIÓN Y\nDIRECCIÓN DE EMPRESAS (MBA ONLINE)",
  title = "Hay muchos MBA,\npero no son como este.",
  description = "El único MBA donde tu proyecto es el eje de todo. Un enfoque exigente y aplicado que transforma el aprendizaje en capacidad real de dirección.",
} = Astro.props;
---

<section class="hero">

  <!-- Background image -->
  <img src="/img/hero-bg.jpg" alt="" class="hero-bg" />

  <!-- Dark overlay -->
  <div class="hero-overlay"></div>

  <!-- Contenido -->
  <div class="hero-content">

    <!-- LEFT -->
    <div class="hero-left">
      <span class="hero-tag">{tag}</span>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-description">{description}</p>
      <!-- CTAs visibles solo en móvil/vertical -->
      <div class="hero-buttons">
        <button class="hero-cta-btn" id="hero-open-modal">CONTACTA ASESOR</button>
      </div>
    </div>

    <!-- RIGHT — tarjeta amarilla con formulario (desktop) -->
    <div class="hero-right">
      <div class="hero-card">
        <div class="hero-card-photo">
          <img src="/img/Rallo_fondo.jpg" alt="Director MBA" />
          <button class="hero-card-play" aria-label="Reproducir vídeo" id="hero-play-btn"></button>
        </div>
        <div class="hero-form-wrap">
          <p class="hero-form-title">CONTACTA CON UN ASESOR ACADÉMICO</p>
          <form class="hero-form" id="mba-form-desktop">
            <div class="form-row">
              <input type="text" name="nombre" placeholder="Nombre" required />
              <input type="text" name="apellidos" placeholder="Apellidos" required />
            </div>
            <div class="form-row">
              <input type="email" name="email" placeholder="Correo electrónico" required />
              <input type="tel" name="telefono" placeholder="Teléfono" required />
            </div>
            <div class="form-row">
              <input type="text" name="provincia" placeholder="Provincia" required />
              <input type="text" name="pais" placeholder="País" required />
            </div>
            <div class="form-footer">
              <label class="form-legal">
              <input type="checkbox" name="acepta" required />                <span>Acepto el <a href="https://hesperides.edu.es/aviso-legal/">aviso legal</a> y la <a href="https://hesperides.edu.es/politica-de-privacidad/">política de privacidad</a></span>
              </label>
              <button type="submit" class="form-submit">ENVIAR SOLICITUD</button>
            </div>
          </form>
        </div>
      </div>
    </div>

  </div>

  <!-- Modal formulario — solo formulario, sin foto -->
  <div class="hero-modal-overlay" id="hero-modal" aria-hidden="true">
    <div class="hero-modal-card">
      <button class="hero-modal-close" id="hero-close-modal" aria-label="Cerrar">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="hero-form-wrap">
        <p class="hero-form-title">CONTACTA CON UN ASESOR ACADÉMICO</p>
        <form class="hero-form" id="mba-form-modal">
          <div class="form-row">
            <input type="text" name="nombre" placeholder="Nombre" required />
            <input type="text" name="apellidos" placeholder="Apellidos" required />
          </div>
          <div class="form-row">
            <input type="email" name="email" placeholder="Correo electrónico" required />
            <input type="tel" name="telefono" placeholder="Teléfono" required />
          </div>
          <div class="form-row">
            <input type="text" name="provincia" placeholder="Provincia" required />
            <input type="text" name="pais" placeholder="País" required />
          </div>
          <div class="form-footer">
            <label class="form-legal">
              <input type="checkbox" name="acepta" required />              <span>Acepto el <a href="https://hesperides.edu.es/aviso-legal/">aviso legal</a> y la <a href="https://hesperides.edu.es/politica-de-privacidad/">política de privacidad</a></span>
            </label>
            <button type="submit" class="form-submit">ENVIAR SOLICITUD</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Bottom menu -->
  <!-- Banda nav desktop -->
  <div class="hero-bottom-menu">
    <div class="hero-bottom-inner">
      <a href="#descripcion">Descripción</a>
      <a href="#programa">Programa</a>
      <a href="#profesores">Profesores</a>
      <a href="#metodologia">Metodología</a>
      <a href="#pagos">Inscripción</a>
    </div>
  </div>

  <div class="hero-info-marquee">
    <div class="hero-marquee-track">
      <div class="hero-marquee-item"><img src="/img/iconoir_graduation-cap.svg" alt="" /><span>Universitario</span></div>
      <div class="hero-marquee-item"><img src="/img/iconoir_calendar.svg" alt="" /><span>Inicio Abril 2026</span></div>
      <div class="hero-marquee-item"><img src="/img/iconoir_alarm.svg" alt="" /><span>1 año</span></div>
      <div class="hero-marquee-item"><img src="/img/iconoir_modern-tv.svg" alt="" /><span>100% online</span></div>
      <div class="hero-marquee-item"><img src="/img/iconoir_euro-square.svg" alt="" /><span>Desde 1.275 €</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_graduation-cap.svg" alt="" /><span>Universitario</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_calendar.svg" alt="" /><span>Inicio Abril 2026</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_alarm.svg" alt="" /><span>1 año</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_modern-tv.svg" alt="" /><span>100% online</span></div>
      <div class="hero-marquee-item" aria-hidden="true"><img src="/img/iconoir_euro-square.svg" alt="" /><span>Desde 1.275 €</span></div>
    </div>
  </div>

</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+HK:wght@200;300;400;500;700&display=swap');

  /* ── Hero ── */
  .hero {
    position: relative;
    width: 100%;
    min-height: 910px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding-inline: clamp(20px, 6.77vw, 130px);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: none;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  /* ── Contenido principal ── */
  .hero-content {
    position: relative;
    z-index: 2;
    flex: 1;
    width: min(1285px, 100%);
    margin-inline: auto;
    box-sizing: border-box;
    padding-block: clamp(40px, 5vw, 80px) 80px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(32px, 4vw, 80px);
    align-items: center;
  }

  /* ── LEFT ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;

  }

  /* Tag amarillo */
  .hero-tag {
    display: block;
    color: #FFCD00;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: clamp(21px, 2.43vw, 48px);
    line-height: 30px;
    letter-spacing: 0.96px;
    text-transform: uppercase;
    white-space: pre-line;
    margin: 0;
  }

  /* Título */
  .hero-title {
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(38px, 4.85vw, 96px);
    line-height: 59px;
    letter-spacing: -1.28px;
    white-space: pre-line;
    margin: 0;
  }

  /* Descripción */
  .hero-description {
    max-width: 530px;
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: clamp(13px, 1.52vw, 30px);
    line-height: 28px;
    letter-spacing: 1px;
    margin: 0;
    opacity: 0.95;
  }

  /* Botones */
  .hero-buttons {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  /* ── RIGHT — tarjeta amarilla ── */
  .hero-right {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    flex-shrink: 0;
    margin-bottom: clamp(20px, 2.27vw, 45px);
  }

  .hero-card {
    position: relative;
    width: 440px;
    border-radius: 29.896px;
    background: #FFCD00;
    box-shadow: 0 7.972px 6.976px 4.983px rgba(0, 0, 0, 0.25);
    overflow: visible;
  }

  /* Foto encima de la tarjeta */
  .hero-card-photo {
    position: relative;
    width: 100%;
    height: 235px;
    border-radius: 29.896px;
    overflow: hidden;
    background: lightgray center top / cover no-repeat;
    background-image: url('/img/Rallo_fondo.jpg');
    background-position: center top;
    background-size: cover;
  }

  .hero-card-photo img {
    display: none;
    width: 500px;
    height: 180px;

  }

  .hero-card-play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: fit-content;
    height: fit-content;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    opacity: 0.45;
    transition: opacity 0.2s ease;
  }

  .hero-card-play:hover {
    opacity: 0.7;
  }

  .hero-card-play::after {
    content: '';
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 18px 0 18px 32px;
    border-color: transparent transparent transparent #FFCD00;
  }

  /* Formulario */
  .hero-form-wrap {
    padding: clamp(16px, 1.82vw, 36px) clamp(18px, 2.12vw, 42px) clamp(18px, 2.12vw, 42px) clamp(25px, 2.88vw, 57px);
  }

  .hero-form-title {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(13px, 1.52vw, 30px);
    line-height: normal;
    letter-spacing: 0.2px;
    color: #1a1a1a;
    margin: 0 0 clamp(11px, 1.21vw, 24px);
  }

  .hero-form {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
  }
  

  .hero-form input[type="text"],
  .hero-form input[type="email"],
  .hero-form input[type="tel"] {
    width: 100%;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.847);
    border-radius: 999px;
    background: #ffcd00;
    padding: 0 clamp(8px, 0.91vw, 18px);
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(8px, 0.91vw, 18px);
    font-weight: 500;
    color: #1a1a1a;
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.2s;
    box-shadow: 1.993px 0 3.986px 0 rgba(0, 0, 0, 0.25);

  }

  .hero-form input::placeholder {
    color: #1a1a1a;
    font-size: clamp(11px, 1.21vw, 24px);
    font-weight: 400;
  }

  .hero-form input:focus {
    border-color: rgba(0,0,0,0.5);
    background: rgba(255,255,255,0.85);
  }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: clamp(3px, 0.30vw, 6px);
  }

  .form-legal {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(8px, 0.83vw, 17px);
    font-weight: 400;
    color: #1a1a1a;
    line-height: 1.4;
    cursor: pointer;
  }

  .form-legal input[type="checkbox"] {
    flex-shrink: 0;
    appearance: none;
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1.5px solid #fffdfd;
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: background 0.2s;
  }

  .form-legal input[type="checkbox"]:checked {
    background: #1a1a1a;
  }

  .form-legal input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 2px;
    width: 5px;
    height: 8px;
    border: 2px solid #FFCD00;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }

  .form-legal a {
    color: #1a1a1a;
    text-decoration: underline;
  }

  .form-submit {
    flex-shrink: 0;
    background: #1a1a1a;
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: clamp(8px, 0.83vw, 17px);
    letter-spacing: 0.06em;
    padding: clamp(7px, 0.76vw, 15px) clamp(13px, 1.52vw, 30px);
    border-radius: 999px;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
  }

  .form-submit:hover {
    background: #333;
  }

  /* ── Info marquee (mobile only) — oculto en desktop ── */
  .hero-info-marquee { display: none; }

  /* ── Bottom menu ── */
  .hero-bottom-menu {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 57px;
    background: rgba(0, 0, 0, 0.43);
    backdrop-filter: blur(7.5px);
    display: flex;
    align-items: center;
  }

  .hero-bottom-inner {
    width: 100%;
    box-sizing: border-box;
    padding: 0 clamp(20px, 6.77vw, 130px);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: clamp(20px, 2.5vw, 48px);
  }

  .hero-bottom-inner a {
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(9px, 0.99vw, 20px);
    font-weight: 300;
    color: #fff;
    text-decoration: none;
    opacity: 0.85;
    letter-spacing: 0.12em;
    transition: opacity 0.2s ease;
  }

  .hero-bottom-inner a:hover {
    opacity: 1;
  }

  /* ── Modal overlay ── */
  .hero-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.65);
    align-items: center;
    justify-content: center;
    padding: clamp(13px, 1.52vw, 30px);
    box-sizing: border-box;
  }
  .hero-modal-overlay.open {
    display: flex;
  }
  .hero-modal-card {
    position: relative;
    background: #FFCD00;
    border-radius: 24px;
    width: 100%;
    max-width: 440px;
    max-height: 90svh;
    overflow-y: auto;
    box-shadow: 0 12px 48px rgba(0,0,0,0.35);
  }
  .hero-modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,0.25);
    background: transparent;
    color: #1a1a1a;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .hero-modal-close:hover { background: rgba(0,0,0,0.1); }
  .hero-modal-photo {
    width: 100% !important;
    height: 220px !important;
    border-radius: 24px 24px 0 0 !important;
    background-position: center top !important;
    background-size: cover !important;
  }

  /* ── Desktop: botón CTA oculto, card visible ── */
  .hero-buttons { display: none; }
  .hero-modal-overlay { display: none; }

  @media (max-width: 1300px) {
    .hero-card { width: clamp(280px, 24vw, 360px); min-height: auto; }
    .hero-card-photo { height: clamp(140px, 16vw, 220px); }
  }

  @media (max-width: 1000px) {
    .hero-card-photo { height: clamp(160px, 18vw, 240px); }
  }

  /* ── Móvil / pantallas verticales ── */
  @media (max-width: 900px) {
    .hero { min-height: 100svh; overflow: hidden; padding-inline: 0; }

    /* hero-content: columna única, texto + card apilados */
    .hero-content {
      flex: unset;
      display: flex;
      flex-direction: column;
      padding-top: 24px;
      padding-left: 5px;
      padding-right: 5px;
      padding-bottom: 20px;
      gap: 32px;
      align-items: flex-start;
    }

    /* Botón CTA más pequeño */
    .hero-buttons {
      display: flex;
      margin-top: 8px;
    }
    .hero-cta-btn {
      background: #FFCD00;
      color: #1a1a1a;
      font-family: "Noto Sans HK", sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.08em;
      padding: 8px 18px;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }
    .hero-cta-btn:hover { background: #fff; }

    /* Tarjeta: flujo normal, encima del marquee */
    .hero-right {
      position: static;
      width: 100%;
      display: flex;
      justify-content: flex-start;
      padding: 0 20px;
      margin: 0;
      box-sizing: border-box;
    }
    .hero-card {
      width: 100%;
      margin-inline: 0;
      max-width: 100%;
      height: auto;
      border-radius: 16px;
      overflow: hidden;
      border: 0.57px solid #FFCD00;
    }
    .hero-card-photo {
      height: 200px;
      border-radius: 0;
      background-size: cover;
      background-position: center top;
    }
    .hero-card .hero-form-wrap { display: none; }
    .hero-modal-card .hero-form-wrap { display: block; }

    /* Play button en amarillo */
    .hero-card-play { opacity: 0.9; }
    .hero-card-play::after {
      border-color: transparent transparent transparent #FFCD00;
    }

    /* Texto — el hero-left lleva su propio padding lateral */
    .hero-left { padding: 0 20px; }
    .hero-tag        { font-size: 16.21px; line-height: 15.19px; letter-spacing: 0.03em; font-weight: 700; white-space: pre-line; }
    .hero-title      { font-size: 31.18px; line-height: 28.87px; letter-spacing: -0.03em; font-weight: 500; white-space: pre-line; }
    .hero-description{ font-size: 14px; line-height: 17px; letter-spacing: 0.02em; font-weight: 300; max-width: 100%; padding-bottom: 8px; padding-right: 40px; }

    /* Modal formulario */
    .hero-modal-card .hero-form-wrap { padding: 20px; }
    .hero-form-title { font-size: 15px; }
    .form-row { grid-template-columns: 1fr; }
    .form-footer { flex-direction: column; align-items: flex-start; gap: 10px; }
    .form-submit { width: 100%; text-align: center; }

    /* Ocultar nav del hero, mostrar marquee info — empujado al fondo */
    .hero-bottom-menu { display: none; }
    .hero-info-marquee {
      display: flex;
      width: 100%;
      margin-left: 0;
      height: 53px;
      background: #0B0B0B;
      align-items: center;
      overflow: hidden;
      position: relative;
      z-index: 2;
      margin-top: 20px;
    }
    .hero-marquee-track {
      display: flex;
      align-items: center;
      gap: 20px;
      width: max-content;
      animation: hero-marquee 14s linear infinite;
    }
    @keyframes hero-marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .hero-marquee-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: "Noto Sans HK", sans-serif;
      font-size: 14px;
      font-weight: 300;
      color: #fff;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .hero-marquee-item img {
      width: 20px;
      height: 20px;
      object-fit: contain;
      display: block;
      opacity: 0.85;
    }

    /* Bottom menu scroll */
    .hero-bottom-inner {
      gap: 10px;
      overflow-x: auto;
      justify-content: flex-start;
      padding: 0 20px;
      scrollbar-width: none;
    }
    .hero-bottom-inner::-webkit-scrollbar { display: none; }
    .hero-bottom-inner a { flex-shrink: 0; }
  }

  @media (min-width: 768px) and (max-width: 900px) {
    .hero-content {
      align-items: center;
    }
    .hero-card {
      width: clamp(320px, 50vw, 480px);
      height: auto;
      margin-inline: auto;
    }
    .hero-card-photo {
      height: clamp(220px, 30vw, 320px);
    }
    .hero {
      min-height: clamp(600px, 80vw, 800px);
    }
  }

  @media (min-width: 901px) {
    .hero { padding-inline: clamp(16px, 1.2vw, 24px); min-height: clamp(500px, 55vw, 750px); overflow: visible; }
    .hero-content { grid-template-columns: 1fr clamp(420px, 38vw, 580px); gap: clamp(20px, 3vw, 60px); }
    .hero-left { min-width: clamp(280px, 35vw, 520px); }
    .hero-bottom-menu { width: calc(100% + 2 * clamp(16px, 1.2vw, 24px)); margin-left: calc(-1 * clamp(16px, 1.2vw, 24px)); }
    .hero-tag { font-size: clamp(14px, 1.4vw, 24px); line-height: 1.3; letter-spacing: 0.06em; }
    .hero-card-titulo { font-size: clamp(12px, 1.1vw, 18px); white-space: nowrap; }
    .hero-form-title { font-size: clamp(11px, 1.1vw, 18px); white-space: nowrap; line-height: 1.2; }
    .hero-title { font-size: clamp(28px, 3vw, 52px); line-height: 1.05; }
    .hero-bottom-menu { width: 100vw; position: relative; left: 50%; transform: translateX(-50%); }
    .hero-description { font-size: clamp(11px, 1vw, 16px); line-height: 1.5; font-weight: 300; max-width: clamp(300px, 40vw, 530px); }
    .hero-form-legal { font-size: clamp(7px, 0.65vw, 11px); white-space: nowrap; line-height: 1.2; }
    .hero-bottom-inner { padding-inline: clamp(20px, 2.5vw, 40px); gap: clamp(40px, 5.5vw, 100px); width: 100%; max-width: 1285px; margin-inline: auto; }
    .hero-bottom-inner a { font-size: clamp(10px, 0.95vw, 17px); font-weight: 400; }
