  // Header amarillo sticky via JS (clase CSS)
  ;(function() {
    function initHeaderSticky() {
      const headerInner = document.querySelector(".header-inner");
      if (!headerInner || window.innerWidth <= 900) return;

      const headerTop = headerInner.getBoundingClientRect().top + window.scrollY;
      const headerHeight = headerInner.offsetHeight;

      const placeholder = document.createElement("div");
      placeholder.style.height = headerHeight + "px";
      placeholder.style.display = "none";
      headerInner.parentNode.insertBefore(placeholder, headerInner.nextSibling);

      let isFixed = false;

      window.addEventListener("scroll", function() {
        if (window.scrollY >= headerTop && !isFixed) {
          headerInner.classList.add("is-fixed");
          placeholder.style.display = "block";
          isFixed = true;
        } else if (window.scrollY < headerTop && isFixed) {
          headerInner.classList.remove("is-fixed");
          placeholder.style.display = "none";
          isFixed = false;
        }
      });
    }

    if (document.readyState === "complete") {
      initHeaderSticky();
    } else {
      window.addEventListener("load", initHeaderSticky);
    }
  })();

  // Sticky bottom menu debajo del header amarillo
  ;(function() {
    function initSticky() {
      const bottomMenu = document.querySelector(".hero-bottom-menu");
      const headerInner = document.querySelector(".header-inner");
      if (!bottomMenu || window.innerWidth <= 900) return;

      const menuOffsetTop = bottomMenu.getBoundingClientRect().top + window.scrollY;

      const placeholder = document.createElement("div");
      placeholder.style.height = bottomMenu.offsetHeight + "px";
      placeholder.style.display = "none";
      bottomMenu.parentNode.insertBefore(placeholder, bottomMenu.nextSibling);

      let isFixed = false;

      window.addEventListener("scroll", function() {
        const hHeight = (headerInner && headerInner.classList.contains("is-fixed")) ? headerInner.offsetHeight : 0;
        const threshold = isFixed
          ? parseFloat(placeholder.getBoundingClientRect().top + window.scrollY)
          : menuOffsetTop;

        if (window.scrollY >= (threshold - hHeight) && !isFixed) {
          bottomMenu.style.position = "fixed";
          bottomMenu.style.top = hHeight + "px";
          bottomMenu.style.left = "0";
          bottomMenu.style.width = "100%";
          bottomMenu.style.zIndex = "100";
          placeholder.style.display = "block";
          isFixed = true;
        } else if (window.scrollY < (threshold - hHeight) && isFixed) {
          bottomMenu.style.position = "";
          bottomMenu.style.top = "";
          bottomMenu.style.left = "";
          bottomMenu.style.width = "";
          bottomMenu.style.zIndex = "";
          placeholder.style.display = "none";
          isFixed = false;
        }
      });
    }

    if (document.readyState === "complete") {
      initSticky();
    } else {
      window.addEventListener("load", initSticky);
    }
  })();


