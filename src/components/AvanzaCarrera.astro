---
// AvanzaCarrera.astro
const features = [
  { titulo: "Título\nEuropeo", destacado: "Oficial",    right: false },
  { titulo: "Plazas",          destacado: "Limitadas",   right: false },
  { titulo: "Metodología\n",  destacado: "del Caso",    right: false },
  { titulo: "91%",             destacado: "Satisfacción\nacadémica", bigNumber: true, right: false },
];
---

<section class="avanza-section">
  <div class="avanza-card">

    <!-- Título -->
    <div class="avanza-titulo-wrap">
      <p class="avanza-titulo">
        No se trata solo de tener un Máster,<br />
        <span class="avanza-titulo-yellow">SE TRATA DE AVANZAR EN TU CARRERA</span>
      </p>
    </div>

    <!-- Feature cards -->
    <div class="avanza-features">
      {features.map((f) => (
        <div class={`feature-card${f.right ? ' feature-card--right' : ''}`}>
          <p class="feature-text">
  <span class={`feature-normal${f.bigNumber ? ' feature-big' : ''}`}>{f.titulo}</span><span class="feature-bold">{f.destacado}</span>
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="avanza-cta-wrap">
      <a href="#" class="avanza-cta">PIDE MÁS INFO</a>
    </div>

  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+HK:wght@300;400;500;700&display=swap');

  /* ── Sección — fondo blanco, la tarjeta monta sobre la sección siguiente ── */
  .avanza-section {
    width: 100%;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(40px, 5vw, 80px) clamp(16px, 4vw, 80px);
    padding-bottom: 0;
    box-sizing: border-box;
    position: relative;
    z-index: 2;
    margin-bottom: -140px;
  }

  /* ── Tarjeta principal glassmorphism ── */
  .avanza-card {
    position: relative;
    z-index: 2;
    width: min(1285px, 100%);
    min-height: 579px;
    border-radius: 65.409px;
    border: 2px solid #FFCD00;
    background: rgba(255, 255, 255, 0.50);
    backdrop-filter: blur(3.634px);
    -webkit-backdrop-filter: blur(3.634px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(32px, 4vw, 56px);
    padding: clamp(40px, 5vw, 72px) clamp(32px, 5vw, 80px);
    box-sizing: border-box;
  }

  /* ── Título ── */
  .avanza-titulo-wrap {
    text-align: center;
  }

  .avanza-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 2.34vw, 45px);
    line-height: 35.563px;
    color: #000;
    text-align: center;
    margin: 0;
  }

  .avanza-titulo-yellow {
    display: block;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: clamp(28px, 2.34vw, 45px);
    line-height: 40px;
    color: #FFCD00;
  }

  /* ── Feature cards ── */
  .avanza-features {
    display: flex;
    flex-direction: row;
    gap: clamp(12px, 2vw, 32px);
    align-items: stretch;
    justify-content: center;
    flex-wrap: wrap;
  }

  .feature-card {
    display: inline-flex;
    width: clamp(140px, 13vw, 220px);
    height: 176px;
    padding: 32px 29px;
    justify-content: flex-start;
    align-items: flex-start;
    border-radius: 30px;
    border: 2px solid #FFCD00;
    background: #fff;
    backdrop-filter: blur(3.634px);
    -webkit-backdrop-filter: blur(3.634px);
    box-sizing: border-box;
    text-align: center;
  }

  .feature-text {
    font-family: "Noto Sans HK", sans-serif;
    font-size: clamp(16px, 1.25vw, 24px);
    font-weight: 400;
    line-height: 27px;
    color: #000;
    margin: 0;
    white-space: pre-line;
    text-align: left;
  }

  .feature-normal {
    font-weight: 400;
  }

  .feature-bold {
    font-weight: 700;
    display: block;
    font-size: inherit;
  }

  /* "Oficial" alineado a la derecha */
  .feature-card--right .feature-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  .feature-card--right .feature-bold {
    align-self: flex-end;
  }

  .feature-big {
    font-weight: 700;
    font-size: clamp(28px, 2.5vw, 48px);
    line-height: 1;
    display: block;
    margin-bottom: 4px;
  }

  /* ── CTA ── */
  .avanza-cta-wrap {
    display: flex;
    justify-content: center;
  }

  .avanza-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 235px;
    height: 45px;
    padding: 0;
    border-radius: 999px;
    background: #1a1a1a;
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .avanza-cta:hover {
    background: #FFCD00;
    color: #000;
  }

  /* ── Responsive mobile ── */
  @media (max-width: 860px) {
    .avanza-section {
      padding: 24px 16px 0;
      margin-bottom: -60px;
    }

    .avanza-card {
      border-radius: 28px;
      min-height: auto;
      gap: 20px;
      padding: 28px 20px;
      width: 100%;
    }

    .avanza-titulo-wrap {
      width: 100%;
    }

    .avanza-titulo {
      font-size: 28px;
      line-height: 26px;
      text-align: left;
    }

    .avanza-titulo-yellow {
      font-size: 30px;
      line-height: 26px;
      text-align: left;
      padding-top: 10px;
      padding-bottom: 15px;
    }

    /* Grid 2x2 */
    .avanza-features {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      width: 100%;
    }

    .feature-card {
      width: 100%;
      height: auto;
      min-height: 100px;
      padding: 16px 14px;
      border-radius: 20px;
    }

    .feature-text {
      font-size: 17px;
      line-height: 12px;
    }

    .feature-bold {
      font-size: 13px;
    }

    .feature-big {
      font-size: 28px;
      line-height: 1;
    }

    .avanza-cta-wrap {
      width: 60%;
    }

    .avanza-cta {
      width: 100%;
      font-size: 15px;
    }
  }
</style>