---
// AvanzaCarrera.astro
const features = [
  { titulo: "Título\nEuropeo", destacado: "Oficial" },
  { titulo: "Plazas\n ",       destacado: "Limitadas" },
  { titulo: "Metodología\ndel Caso" },
  { titulo: "91%\n ",          destacado: "Satisfacción académica", bigNumber: true },
];
---

<section class="avanza-section">
  <div class="avanza-card">

    <p class="avanza-titulo">
      No se trata solo de tener un Máster,<br />
      <span class="avanza-titulo-yellow">SE TRATA DE AVANZAR EN TU CARRERA</span>
    </p>

    <div class="avanza-features">
      {features.map((f) => (
        <div class="feature-card">
          <div class="feature-inner">
            {f.bigNumber
              ? <>
                  <span class="feature-big">{f.titulo.split('\n')[0]}</span>
                  <span class="feature-regular">{f.destacado}</span>
                </>
              : f.destacado
              ? <>
                  <span class="feature-normal">{f.titulo}</span>
                  <span class="feature-bold">{f.destacado}</span>
                </>
              : <>
                  <span class="feature-normal">{f.titulo.split('\n')[0]}</span>
                  <span class="feature-bold">{f.titulo.split('\n')[1]}</span>
                </>
            }
          </div>
        </div>
      ))}
    </div>

    <div class="avanza-cta-wrap">
      <a href="#" class="avanza-cta">PIDE MÁS INFO</a>
    </div>

  </div>
</section>

<style>
  /* ── Sección: fondo transparente, monta POCO sobre el amarillo ── */
  .avanza-section {
    width: 100%;
    background: transparent;
    display: flex;
    justify-content: center;
    padding: clamp(40px, 5vw, 80px) clamp(20px, 6.77vw, 130px) 0;
    box-sizing: border-box;
    position: relative;
    z-index: 2;
    margin-bottom: -80px; /* pisa poquito */
  }

  /* ── Card glassmorphism ── */
  .avanza-card {
    width: min(1285px, 100%);
    min-height: 579px;
    border-radius: 65px;
    border: 2px solid #FFCD00;
    background: rgba(255, 255, 255, 0.50);
    backdrop-filter: blur(3.634px);
    -webkit-backdrop-filter: blur(3.634px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(32px, 4vw, 52px);
    padding: clamp(40px, 5vw, 72px) clamp(32px, 5vw, 80px);
    box-sizing: border-box;
    position: relative;
    z-index: 2;
  }

  /* ── Título ── */
  .avanza-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: clamp(24px, 2.34vw, 45px);
    line-height: 1.2;
    color: #000;
    text-align: center;
    margin: 0;
  }

  .avanza-titulo-yellow {
    display: block;
    font-weight: 700;
    color: #FFCD00;
  }

  /* ── Features: 4 cards en fila ── */
  .avanza-features {
    display: flex;
    flex-direction: row;
    gap: clamp(12px, 1.5vw, 24px);
    align-items: stretch;
    justify-content: center;
  }

  /* ── Card feature ── */
  .feature-card {
    width: clamp(140px, 13vw, 220px);
    height: 176px;
    border-radius: 30px;
    border: 2px solid #FFCD00;
    background: #fff;
    box-sizing: border-box;
    /* centrado vertical y horizontal */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  /* Inner: columna, título arriba bold, subtítulo abajo */
  .feature-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
    height: 100%;
  }

  .feature-normal {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(14px, 1.1vw, 20px);
    line-height: 1.3;
    color: #000;
    white-space: pre-line;
  }

  .feature-bold {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: clamp(14px, 1.1vw, 20px);
    line-height: 1.3;
    color: #000;
  }

  /* 91% grande */
  .feature-big {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: clamp(32px, 2.8vw, 52px);
    line-height: 1;
    color: #000;
  }

  /* "Satisfacción académica" en regular, no bold */
  .feature-regular {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(13px, 1vw, 18px);
    line-height: 1.3;
    color: #000;
  }

  /* ── CTA ── */
  .avanza-cta-wrap {
    display: flex;
    justify-content: center;
  }

  .avanza-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 235px;
    height: 45px;
    border-radius: 999px;
    background: #1a1a1a;
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .avanza-cta:hover {
    background: #FFCD00;
    color: #000;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .avanza-section {
      padding: 24px 16px 0;
      margin-bottom: -40px;
    }
    .avanza-card {
      border-radius: 28px;
      min-height: auto;
    }
    .avanza-features {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      width: 100%;
    }
    .feature-card {
      width: 100%;
      height: 140px;
    }
  }
</style>