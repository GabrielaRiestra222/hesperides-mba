---
// ConvierteAmbicion.astro

const features = [
  {
    titulo: "APRENDE A DIRIGIR CON IA",
    texto: "La Inteligencia Artificial no es una herramienta. Es una decisión estratégica. Aprende a liderarla.",
  },
  {
    titulo: "CASOS REALES",
    texto: "Trabajarás durante el MBA en diseñar el modelo de negocio de tu proyecto o en transformar el de tu empresa o sector. Tú decides el foco.",
  },
  {
    titulo: "DEFINE TU CAMINO",
    texto: "¿Marketing o Finanzas? Podrás escoger entre estas dos especializaciones, según lo prefieras para tu orientación profesional.",
  },
];
---

<section class="convierte-section">
  <!--
    .section-inner viene de global.css:
      max-width: 1280px
      margin: 0 auto
      padding: clamp(24px, 16.67vw, 320px)
    Garantiza la misma línea imaginaria que el resto del sitio.
  -->
  <div class="section-inner convierte-inner">

    <!-- Fila superior: título+desc | 3 features con líneas -->
    <div class="convierte-top">

      <div class="convierte-texto">
        <h2 class="convierte-titulo">
          Convierte tu <strong>ambición</strong> en
          <strong>capacidad real de dirección</strong>
        </h2>
        <p class="convierte-desc">
          Adquiere la disciplina analítica y la mentalidad estratégica necesarias para dirigir organizaciones.
        </p>
      </div>

      <div class="features-row">
        {features.map((f) => (
          <div class="feature-item">
            <div class="feature-line"></div>
            <div class="feature-block">
              <h3 class="feature-titulo">{f.titulo}</h3>
              <p class="feature-texto">{f.texto}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Fila inferior: foto + cita -->
    <div class="convierte-quote-row">

      <div class="quote-foto">
        <img src="/img/bd4c3e13620a9a361db702e39aa47953d787f732.jpg" alt="Juan Carlos Andreu" />
      </div>

      <div class="quote-content">
        <div class="quote-stars">★★★★★</div>
        <blockquote class="quote-text">
          "Un programa que te pide constancia. Y te devuelve criterio, método y crecimiento profesional"
        </blockquote>
        <div class="quote-author">
          <p class="author-name">Juan Carlos Andreu</p>
          <p class="author-cargo">Associate Director at World Wealth Management (WWM)<br />y director del MBA de la Universidad de las Hespérides.</p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ── Sección ── */
  .convierte-section {
    width: 100%;
    background: url('/img/b4e63b1bca93910c5d5146826110ac7fdda11645.jpg') center / cover no-repeat;
    padding-top: clamp(80px, 9.375vw, 180px);
    padding-bottom: clamp(60px, 6.25vw, 120px);
  }

  /* ── Inner: solo flex column + gap sobre .section-inner ── */
  .convierte-inner {
    display: flex;
    flex-direction: column;
    gap: clamp(48px, 5vw, 96px);
  }

  /* ================================================================
     MOBILE (base) — todo apilado
     ================================================================ */
  .convierte-top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
  }

  .convierte-texto {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .convierte-titulo {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(26px, 2.08vw, 40px);
    line-height: 1.15;
    margin: 0;
  }

  .convierte-titulo strong {
    font-weight: 700;
  }

  .convierte-desc {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: clamp(13px, 0.885vw, 17px);
    line-height: 1.6;
    letter-spacing: 0.3px;
    margin: 0;
  }

  .features-row {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    min-width: 0;
  }

  .feature-line {
    width: 1px;
    align-self: stretch;
    background: rgba(0, 0, 0, 0.25);
    flex-shrink: 0;
  }

  .feature-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    flex: 1;
    min-width: 0;
  }

  .feature-titulo {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: clamp(13px, 1.04vw, 20px);
    line-height: 1.3;
    margin: 0;
  }

  .feature-texto {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: clamp(12px, 0.885vw, 17px);
    line-height: 1.55;
    margin: 0;
  }

  /* Testimonial — alineado por arriba en mobile */
  .convierte-quote-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    width: 100%;
  }

  .quote-foto {
    width: 100%;
    width: 100%;
    flex-shrink: 0;
    border-radius: 12px;
    overflow: hidden;
  }

  .quote-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .quote-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }

  .quote-stars {
    color: #FFCD00;
    font-size: 22px;
    letter-spacing: 4px;
    line-height: 1;
  }

  .quote-text {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(20px, 1.875vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin: 0;
    quotes: none;
  }

  .quote-author {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .author-name {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #000;
    margin: 0;
  }

  .author-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: 12px;
    line-height: 1.5;
    color: #000;
    margin: 0;
    opacity: 0.75;
  }

  /* ================================================================
     TABLET (≥700px) — features en fila, testimonial en fila
     ================================================================ */
  @media (min-width: 700px) {
    .features-row {
      flex-direction: row;
      gap: 0;
    }
    .feature-item {
      flex: 1;
    }
    .convierte-quote-row {
      flex-direction: row;
      align-items: center;
      gap: 40px;
    }
    .quote-foto {
      width: clamp(180px, 22vw, 300px);
      max-width: none;
    }
  }

  /* ================================================================
     DESKTOP (≥1024px) — fila superior horizontal
     ================================================================ */
  @media (min-width: 1024px) {
    .convierte-top {
      flex-direction: row;
      align-items: flex-start;
      gap: 48px;
    }
    .convierte-texto {
      width: 363px;
      flex-shrink: 0;
    }
    .features-row {
      flex: 1;
      width: auto;
    }
    .convierte-quote-row {
      flex-direction: row;
      align-items: center; /* foto y cita centradas verticalmente entre sí */
      justify-content: flex-start;
      gap: 48px;
    }
    .quote-foto {
      width: clamp(240px, 25vw, 360px);
      aspect-ratio: 3 / 4;
    }
  }
</style>