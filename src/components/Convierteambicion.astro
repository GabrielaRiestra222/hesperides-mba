---
// ConvierteAmbicion.astro

const features = [
  {
    titulo: "APRENDE A\n DIRIGIR CON IA",
    texto: "La Inteligencia Artificial no es una herramienta. Es una decisión estratégica. Aprende a liderarla.",
  },
  {
    titulo: "CASOS REALES",
    texto: "Trabajarás durante el MBA en diseñar el modelo de negocio de tu proyecto o en transformar el de tu empresa o sector. Tú decides el foco.",
  },
  {
    titulo: "DEFINE TU CAMINO",
    texto: "¿Marketing o Finanzas? Podrás escoger entre estas dos especializaciones, según lo prefieras para tu orientación profesional.",
  },
];
---

<section class="convierte-section">
  <!--
    .section-inner viene de global.css:
      max-width: 1280px
      margin: 0 auto
      padding: clamp(24px, 16.67vw, 320px)
    Garantiza la misma línea imaginaria que el resto del sitio.
  -->
  <div class="convierte-inner">

    <!-- Fila superior: título+desc | 3 features con líneas -->
    <div class="convierte-top">

      <div class="convierte-texto">
        <h2 class="convierte-titulo">
          Convierte tu <strong>ambición</strong> en
          <strong>capacidad real de dirección</strong>
        </h2>
        <p class="convierte-desc">
          Adquiere la disciplina analítica y la mentalidad estratégica necesarias para dirigir organizaciones.
        </p>
      </div>

      <div class="features-row">
        {features.map((f) => (
          <div class="feature-item">
            <div class="feature-line"></div>
            <div class="feature-block">
              <h3 class="feature-titulo">{f.titulo}</h3>
              <p class="feature-texto">{f.texto}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Fila inferior: foto + cita -->
    <div class="convierte-quote-row">

      <div class="quote-foto">
        <img src="/img/bd4c3e13620a9a361db702e39aa47953d787f732.jpg" alt="Juan Carlos Andreu" />
      </div>

      <div class="quote-content">
        <blockquote class="quote-text">
          "Un programa que te pide constancia. Y te devuelve criterio, método y crecimiento profesional"
        </blockquote>
        <div class="quote-author">
          <p class="author-name">Juan Carlos Andreu</p>
          <p class="author-cargo">Associate Director at World Wealth Management (WWM)<br />y director del MBA de la Universidad de las Hespérides.</p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ── Sección ── */
  .convierte-section {
    width: 100%;
    background: url('/img/b4e63b1bca93910c5d5146826110ac7fdda11645.jpg') center / cover no-repeat;
    padding-top: clamp(80px, 9.375vw, 180px);
    padding-bottom: clamp(60px, 6.25vw, 120px);
  }

  /* ── Inner ── */
  .convierte-inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 16.67vw, 320px);
    display: flex;
    flex-direction: column;
    gap: clamp(48px, 5vw, 96px);
  }

  @media (max-width: 900px) {
    .convierte-inner { padding: 0 35px 0 25px; overflow: hidden; margin: 0 auto; margin-right: 50px;}

    .convierte-titulo { font-size: 44px; line-height: 1.1; text-align: left; max-width: 100%; }
    .convierte-desc   { font-size: 13px; line-height: 1.5; text-align: left; max-width: 100%; font-weight: 400; }
    .convierte-texto  { align-items: flex-start; }

    /* Quote: foto + texto alineados a la izquierda */
    .convierte-quote-row { flex-direction: column; align-items: flex-start; gap: 16px; }
    .quote-foto { width: 100%; height: 220px; margin: 0; border-radius: 20px; flex-shrink: 0; overflow: hidden; }
    .quote-foto img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
    .quote-content { align-items: flex-start; width: 100%; }
    .quote-text { font-size: 16px; max-width: 100%; text-align: left; }
    .author-name { font-size: 12px; max-width: 100%; text-align: left; }
    .author-cargo { font-size: 11px; max-width: 100%; text-align: left; }

    .features-row { width: 100%; }
    .feature-line { display: none; }
    .feature-item {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-areas: "titulo texto";
      column-gap: 16px;
      align-items: start;
      padding: 14px 0;
      border-top: 0.5px solid rgba(0,0,0,0.2);
    }
    .feature-block { display: contents; }
    .feature-titulo { grid-area: titulo; font-size: 13px; line-height: 1.3; font-weight: 700; white-space: pre-line; }
    .feature-texto  { grid-area: texto;  font-size: 12px; line-height: 1.5; margin: 0; font-weight: 400; }
  }

  /* ── Top block ── */
  .convierte-top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
  }

  .convierte-texto {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .convierte-titulo {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: 30px;
    line-height: 1.15;
    margin: 0;
  }

  .convierte-titulo strong { font-weight: 700; }

  .convierte-desc {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 20px;
    letter-spacing: 0.3px;
    margin: 0;
  }

  /* ── Features ── */
  .features-row {
    width: 100%;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* Mobile: cada item separado por línea horizontal */
  .feature-item {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px 0;
    min-width: 0;
  }

  .feature-line {
    width: 100%;
    height: 1px;
    background: #000;
    flex-shrink: 0;
  }

  .feature-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  .feature-titulo {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: 22px;
    line-height: 1.3;
    margin: 0;
    white-space: pre-line;
  }

  .feature-texto {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: 18px;
    line-height: 1.5;
    margin: 0;
  }

  /* ── Quote row ── */
  .convierte-quote-row {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 24px;
    width: 100%;
  }

  .quote-foto {
    width: 100%;
    flex-shrink: 0;
    border-radius: 20px;
    overflow: hidden;
  }

  .quote-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .quote-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }

  .quote-text {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(20px, 1.875vw, 36px);
    line-height: 1.2;
    letter-spacing: -0.5px;
    margin: 0;
    quotes: none;
  }

  .quote-author {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .author-name {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #000;
    margin: 0;
  }

  .author-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: 12px;
    line-height: 1.5;
    color: #000;
    margin: 0;
    opacity: 0.75;
  }

  /* ================================================================
     DESKTOP (≥860px)
     ================================================================ */
  @media (min-width: 860px) {
    .features-row {
      flex-direction: row;
      gap: 0;
    }
    .feature-item {
      flex: 1;
      flex-direction: row;
      align-items: flex-start;
      padding: 0;
      gap: 30px;
      margin-left: 20px;
    }
    .feature-line {
      width: 1px;
      height: 230px;
      align-self: stretch;
    }
    .feature-titulo { font-size: 25px; }
    .feature-texto {
      font-size: 20px;
      line-height: 21px;
      margin-top: 60px;
    }
    /* Quote row: foto + cita centradas */
    .convierte-quote-row {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 48px;
    }
    .quote-foto {
      width: 100%;
      height: 100%;
      border-radius: 20px;
      flex-shrink: 0;
      overflow: hidden;
    }
    .quote-foto img {
      width: 100%;
      height: 100%;
      object-position: center top;
    }
    .quote-content {
      max-width: 480px;
    }
  }

  /* ================================================================
     DESKTOP GRANDE (≥1024px)
     ================================================================ */
  @media (min-width: 1024px) {
    .convierte-top {
      flex-direction: row;
      align-items: flex-start;
      gap: 48px;
    }
    .convierte-texto {
      width: 363px;
      flex-shrink: 0;
    }
    .features-row {
      flex: 1;
      width: auto;
    }
    .quote-foto {
      width: clamp(280px, 28vw, 420px);
      height: 300px;
      border-radius: 50px;
    }
    .quote-content {
      max-width: 520px;
    }
  }
</style>