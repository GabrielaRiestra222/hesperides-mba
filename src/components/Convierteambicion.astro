---
// ConvierteAmbicion.astro

const features = [
  {
    titulo: "APRENDE A DIRIGIR CON IA",
    texto: "La Inteligencia Artificial no es una herramienta. Es una decisión estratégica. Aprende a liderarla.",
  },
  {
    titulo: "CASOS REALES",
    texto: "Trabajarás durante el MBA en diseñar el modelo de negocio de tu proyecto o en transformar el de tu empresa o sector. Tú decides el foco.",
  },
  {
    titulo: "DEFINE TU CAMINO",
    texto: "¿Marketing o Finanzas? Podrás escoger entre estas dos especializaciones, según lo prefieras para tu orientación profesional.",
  },
];
---

<section class="convierte-section">
  <div class="convierte-inner">

    <!-- Fila superior: título+desc | 3 features con líneas -->
    <div class="convierte-top">

      <!-- Bloque izquierdo: título + descripción -->
      <div class="convierte-texto">
        <h2 class="convierte-titulo">
          Convierte tu<br />
          <strong>ambición</strong> en<br />
          capacidad real de<br />
          dirección
        </h2>
        <p class="convierte-desc">
          Adquiere la disciplina analítica y la mentalidad estratégica necesarias para dirigir organizaciones.
        </p>
      </div>

      <!-- 3 features con líneas separadoras -->
      <div class="features-row">
        {features.map((f) => (
          <div class="feature-item">
            <div class="feature-line"></div>
            <div class="feature-block">
              <h3 class="feature-titulo">{f.titulo}</h3>
              <p class="feature-texto">{f.texto}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Fila inferior: foto + cita, centrada -->
    <div class="convierte-quote-row">

      <div class="quote-foto">
        <img src="/img/bd4c3e13620a9a361db702e39aa47953d787f732.jpg" alt="Juan Carlos Andreu" />
      </div>

      <div class="quote-content">
        <blockquote class="quote-text">
          "Un programa que te pide constancia. Y te devuelve criterio, método y crecimiento profesional"
        </blockquote>
        <div class="quote-author">
          <p class="author-name">Juan Carlos Andreu</p>
          <p class="author-cargo">Associate Director at World Wealth Management (WWM)<br />y director del MBA de la Universidad de las Hespérides.</p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .convierte-section {
    width: 100%;
    background: url('/img/b4e63b1bca93910c5d5146826110ac7fdda11645.jpg') center / cover no-repeat;
    padding-top: 180px;
    padding-bottom: clamp(60px, 7vw, 120px);
    box-sizing: border-box;
    position: relative;
    z-index: 0;
  }

  .convierte-inner {
    width: 100%;
    padding: 0 clamp(20px, 6.77vw, 130px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  /* ── Fila superior ── */
  .convierte-top {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 0;
  }

  /* ── Bloque texto izquierdo ── */
  .convierte-texto {
    /* width del bloque de texto Figma */
    width: 377px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    /* gap: 31px entre él y la primera línea — gestionado por features-row gap */
  }

  .convierte-titulo {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 2.08vw, 40px);
    line-height: 35px;
    margin: 0;
  }

  .convierte-titulo strong { font-weight: 700; }

  .convierte-desc {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: clamp(14px, 1.04vw, 20px);
    line-height: 28px;
    letter-spacing: 1px;
    margin: 0;
  }

  /* ── Features row — líneas + bloques de texto ── */
  .features-row {
    flex: 1;
    display: inline-flex;
    align-items: stretch;
    gap: 31px;
  }

  /* Cada item: línea vertical + bloque texto */
  .feature-item {
    display: inline-flex;
    align-items: flex-start;
    gap: 31px;
    flex: 1;
  }

  /* Línea vertical */
  .feature-line {
    width: 1px;
    align-self: stretch;
    background: rgba(0, 0, 0, 0.25);
    flex-shrink: 0;
  }

  /* Bloque texto de cada feature */
  .feature-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    flex: 1;
  }

  .feature-titulo {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: 24px;
    line-height: 28px;
    margin: 0;
    width: 220px;
    max-height: 49px;
  }

  .feature-texto {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: 17px;
    line-height: 21px;
    margin: 0;
    width: 244px;
  }

  /* ── Fila inferior: foto + cita centradas ── */
  .convierte-quote-row {
    width: 924px;
    height: 301px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: clamp(24px, 3vw, 48px);
  }

  .quote-foto {
    width: 460px;
    height: 307px;
    aspect-ratio: 460 / 307;
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
  }

  .quote-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .quote-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-bottom: 8px;
  }

  .quote-text {
    color: #000;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(24px, 2.08vw, 40px);
    line-height: 40px;
    letter-spacing: -1.2px;
    margin: 0;
    quotes: none;
    max-width: 422px;
  }

  .author-name {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #000;
    margin: 0 0 4px;
  }

  .author-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: 12px;
    line-height: 1.5;
    color: #000;
    margin: 0;
    opacity: 0.75;
  }

  /* ── Responsive ── */
  @media (max-width: 1200px) {
    .convierte-top { flex-direction: column; gap: 40px; }
    .convierte-texto { width: 100%; }
    .features-row { flex-wrap: wrap; }
    .feature-titulo { width: auto; }
    .feature-texto { width: auto; }
    .convierte-quote-row { width: 100%; height: auto; }
    .quote-foto { width: 100%; max-width: 460px; height: auto; }
  }

  @media (max-width: 700px) {
    .features-row { flex-direction: column; }
    .convierte-quote-row { flex-direction: column; align-items: flex-start; }
    .convierte-section { padding-top: 120px; }
  }
</style>