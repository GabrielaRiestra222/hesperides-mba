---

<section class="avales-section" id="metodologia">
  <div class="avales-inner">

    <div class="avales-carousel-wrap">

      <!-- Flecha izquierda (desktop) -->
      <button class="avales-arrow avales-arrow--prev avales-arrow--desktop" id="avales-prev" aria-label="Anterior">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M9.5 2L4.5 7.5L9.5 13" stroke="#000000" stroke-width="1.64" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <div class="avales-col">
        <h2 class="avales-titulo">
          Nuestros avales<br />
          <strong>SE PRESENTAN SOLOS</strong>
        </h2>

        <div class="avales-overflow">
          <div class="avales-track" id="avales-track">
            {avales.map((aval) => (
              <div class="aval-card">
                <div class="aval-header">
                  <div class="aval-foto">
                    <img src={aval.foto} alt={aval.nombre} />
                  </div>
                  <div class="aval-identidad">
                    <p class="aval-nombre">{aval.nombre}</p>
                    <p class="aval-cargo">{aval.cargo}</p>
                  </div>
                </div>
                <p class="aval-texto">{aval.texto}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="avales-arrows-row">
          <button class="avales-arrow avales-arrow--prev avales-arrow--mobile" aria-label="Anterior">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M9.5 2L4.5 7.5L9.5 13" stroke="#000000" stroke-width="1.64" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="avales-arrow avales-arrow--next avales-arrow--mobile" aria-label="Siguiente">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M5.5 2L10.5 7.5L5.5 13" stroke="#000000" stroke-width="1.64" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>

      <!-- Flecha derecha (desktop) -->
      <button class="avales-arrow avales-arrow--next avales-arrow--desktop" id="avales-next" aria-label="Siguiente">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M5.5 2L10.5 7.5L5.5 13" stroke="#000000" stroke-width="1.64" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+HK:wght@200;300;400;500;700&display=swap');

  /* ── Sección ── */
  .avales-section {
    width: 100%;
    min-height: clamp(600px, 44.5vw, 854px);
    background: #F5F4F4;
    padding: clamp(60px, 6vw, 100px) 0;
    padding-inline: clamp(20px, 16.67vw, 320px);
    display: flex;
    align-items: center;
  }

  /* ── Inner: sistema global de márgenes ── */
  .avales-inner {
    width: min(1285px, 100%);
    margin-inline: auto;
    padding: 0;
  }

  /* ── Título ── */
  .avales-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 2.3vw, 45px);
    line-height: 40px;
    color: #1a1a1a;
    margin: 0;
  }

  .avales-titulo strong {
    font-weight: 700;
    color: #FFCD00;
    white-space: nowrap;
  }

  /* ── Carousel wrapper ── */
  .avales-carousel-wrap {
    display: grid;
    grid-template-columns: 36px 1fr 36px;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  .avales-col {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 3.5vw, 56px);
    overflow: hidden;
  }

  /* Desktop: flechas laterales visibles, row oculto */
  .avales-arrow--desktop { display: flex; }
  .avales-arrows-row { display: none; }

  /* ── Flechas ── */
  .avales-arrow {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.64px solid #000;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
    z-index: 2;
  }

  .avales-arrow:hover {
    background: #FFCD00;
    border-color: #FFCD00;
  }

  .avales-arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  /* ── Overflow clip ── */
  .avales-overflow {
    overflow: hidden;
    width: 100%;
  }

  /* ── Track ── */
  .avales-track {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
    padding-bottom: clamp(11px, 1.21vw, 24px);
  }

  /* ── Card — 4 visibles, ancho dinámico ── */
  .aval-card {
    flex: 0 0 calc((100% - 3 * 20px) / 4);
    width: calc((100% - 3 * 20px) / 4);
    height: 350px;
    background: #fff;
    border-top-left-radius: 45px;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    box-shadow: 2px 6px 12px 4px rgba(0, 0, 0, 0.25);
    padding: clamp(10px, 1.14vw, 23px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-sizing: border-box;
    overflow: hidden;
  }

  .aval-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  .aval-identidad {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  .aval-nombre {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(10px, 1.11vw, 22px);
    line-height: 19.556px;
    color: #000;
    margin: 0;
    word-break: break-word;
  }

  .aval-cargo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 200;
    font-size: clamp(8px, 0.83vw, 17px);
    line-height: 13px;
    color: #000;
    margin-top: clamp(4px, 0.38vw, 8px);
    word-break: break-word;
  }

  /* Foto: 103px fija */
  .aval-foto {
    flex-shrink: 0;
    flex-grow: 0;
    width: 103px;
    height: 103px;
    min-width: 103px;
    min-height: 103px;
    border-radius: 50%;
    overflow: hidden;
    background: #e8e8e8;
  }

  .aval-foto img {
    width: 103px;
    height: 103px;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .aval-texto {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(8px, 0.91vw, 18px);
    line-height: 18px;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    margin: 0;
    flex: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .avales-section { min-height: unset; padding: 48px 0; }
    .avales-inner { padding: 0 20px; overflow: hidden; margin-right: 20px; margin-left: 20px;}
    .avales-titulo { font-size: 28px; line-height: 36px; }

    .avales-carousel-wrap {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }

    .avales-arrow--desktop { display: none !important; }
    .avales-arrows-row {
      display: flex;
      gap: 12px;
      margin-top: 24px;
      justify-content: center;
      width: 100%;
    }

    .avales-col { width: 100%; overflow: hidden; }

    .aval-card {
      flex: 0 0 80vw;
      width: 80vw;
      min-height: 420px;
      box-sizing: border-box;
      padding: 24px;
    }
    .aval-foto  { width: 80px; height: 80px; }
    .aval-nombre { font-size: 16px; }
    .aval-cargo  { font-size: 12px; line-height: 16px; }
    .aval-texto  { font-size: 16px; line-height: 26px; }
    .avales-track { gap: 16px; }
  }
  @media (min-width: 901px) {


    /* 3 cards visibles → más anchas, contenido proporcional */
     .aval-card {
    flex: 0 0 calc((100% - 3 * 16px) / 4.10);
    width: calc((100% - 3 * 16px) / 4.10);
min-height: 240px;
  height: auto;  }
    .aval-foto{
  width: 70px;
  height: 70px;
  min-width: 70px;
  min-height: 70px;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
  margin-top: 0;
  flex-shrink: 0;
}

.aval-foto img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

  .aval-header{
    align-items: flex-start;
    gap: 0.5rem;
    padding-top: 0;
    margin-bottom: 0;
    margin-top: clamp(4px, 0.4vw, 8px);
  }

  /* nombre más pequeño */
  .aval-nombre{
    font-size: clamp(8px, 0.85vw, 16px);
    line-height: 16px;
    margin-top: clamp(6px, 0.6vw, 10px);
  }

  /* cargo más pequeño */
  .aval-cargo{
    font-size: clamp(6px, 0.65vw, 12px);
    line-height: 1.2;
    margin-top: clamp(1px, 0.15vw, 3px);
  }

  /* texto del aval */
  .aval-texto{
    font-size: clamp(7px, 0.75vw, 14px);
    line-height: 1.4;
    padding-right: clamp(4px, 0.5vw, 8px);
    margin-top: clamp(8px, 0.8vw, 14px);
  }

  /* menos espacio interno de la card */
  .aval-card{
    padding: clamp(8px, 0.91vw, 18px);
    gap: 0.625rem;
    overflow: hidden;
    box-shadow: 2px 6px 12px 4px rgba(0, 0, 0, 0.25);
  }

  .avales-track {
    gap: clamp(12px, 1.5vw, 20px);
  }

    .avales-carousel-wrap{
    position: relative;
    display:block;
  }

  .avales-arrow {
    border: none;
    border-radius: 0;
    background: transparent;
  }

  .avales-arrow--desktop{
    position:absolute;
    top:50%;
    transform:translateY(-50%);
  }

  .avales-arrow--prev{
    left:-60px;
  }

  .avales-arrow--next{
    right:-60px;
  }

}

  @media (min-width: 1500px) {
    .aval-card { min-height: 320px; }
  }

</style>

<script>
  const track = document.getElementById('avales-track');
  const prevBtns = document.querySelectorAll('.avales-arrow--prev');
  const nextBtns = document.querySelectorAll('.avales-arrow--next');

  if (track && prevBtns.length && nextBtns.length) {
    function getStep(): number {
      if (window.innerWidth <= 860) return window.innerWidth * 0.80 + 16;
      const firstCard = track.children[0] as HTMLElement;
      return firstCard ? firstCard.offsetWidth + 20 : 260 + 20;
    }

    const totalCards = track.children.length;

    function getVisible(): number {
      const w = window.innerWidth;
      if (w >= 860) return 4;
      if (w >= 700) return 2;
      return 1;
    }

    let current = 0;

    function maxIndex(): number {
      return Math.max(0, totalCards - getVisible());
    }

    function updateButtons() {
      prevBtns.forEach(b => (b as HTMLButtonElement).disabled = current === 0);
      nextBtns.forEach(b => (b as HTMLButtonElement).disabled = current >= maxIndex());
    }

    function goTo(index: number) {
      current = Math.max(0, Math.min(index, maxIndex()));
      (track as HTMLElement).style.transform = `translateX(-${current * getStep()}px)`;
      updateButtons();
    }

    prevBtns.forEach(btn => btn.addEventListener('click', () => goTo(current - 1)));
    nextBtns.forEach(btn => btn.addEventListener('click', () => goTo(current + 1)));

    window.addEventListener('resize', () => goTo(Math.min(current, maxIndex())));

    let touchStartX = 0;
    let touchEndX = 0;
    const overflow = track.parentElement as HTMLElement;
    overflow.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    overflow.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 40) {
        if (diff > 0) goTo(current + 1);
        else goTo(current - 1);
      }
    }, { passive: true });

    updateButtons();
  }
</script>