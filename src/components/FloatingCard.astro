---
// FloatingCard.astro
---

<section class="relative z-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <div
      class="
        bg-white
        rounded-[32px]
        shadow-xl
        border border-[#FFCD00]/30
        px-12 py-16
        -translate-y-32
      "
    >
      <h3 class="text-xl font-semibold text-gray-900 mb-2">
        No se trata solo de tener un Master,
      </h3>

      <h2 class="text-3xl font-bold text-[#FFCD00] mb-10 uppercase">
        Se trata de avanzar en tu carrera
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-start">
        <div class="bg-[#FFF3C4] rounded-2xl p-6 text-center">
          <p class="font-semibold">Título Europeo</p>
          <p class="font-bold">Oficial</p>
        </div>

        <div class="bg-[#FFF3C4] rounded-2xl p-6 text-center">
          <p class="font-semibold">Plazas</p>
          <p class="font-bold">Limitadas</p>
        </div>

        <div class="bg-[#FFF3C4] rounded-2xl p-6 text-center">
          <p class="font-semibold">Metodología</p>
          <p class="font-bold">Harvard</p>
        </div>

        <div class="bg-[#1F1F1F] text-[#FFCD00] rounded-2xl p-6 text-center">
          <p class="text-2xl font-bold">78%</p>
          <p class="uppercase text-sm">Empleabilidad</p>
        </div>
      </div>

      <div class="mt-10 flex justify-end">
        <a
          href="#"
          class="bg-black text-[#FFCD00] px-8 py-3 rounded-full text-sm font-semibold hover:opacity-80 transition"
        >
          Quiero saber más
        </a>
      </div>
    </div>
  </div>
</section>
