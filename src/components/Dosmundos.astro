---
// DosMundos.astro — Sección "Lo mejor de los dos mundos"
import videoPortada from '../img/Screenshot 2026-02-27 at 22.05.43.png';

const features = [
  { titulo: "Clases sincrónicas", texto: "Clases colaborativas y en directo." },
  { titulo: "Clases asincrónicas", texto: "Sesiones guiadas con vídeos pregrabados." },
  { titulo: "Tutorías", texto: "Videoconferencias en tiempo real para resolver dudas." },
  { titulo: "Evaluación virtual", texto: "Exámenes online." },
  { titulo: "Campus interactivo", texto: "Interactúa de manera virtual con tus profesores y compañeros en el metaverso." },
];
---

<section class="dosmundos-section">
  <div class="section-inner dosmundos-inner">

    <!-- Fila superior: video izq + texto dcha -->
    <div class="dosmundos-top">

      <div class="dosmundos-video">
        <a
          href="https://youtu.be/0ZyIsN9-sHg"
          target="_blank"
          rel="noopener noreferrer"
          class="video-link"
          aria-label="Ver vídeo: Lo mejor de los dos mundos"
        >
          <img
            src={videoPortada.src}
            alt="Lo mejor de los dos mundos — Universidad de las Hespérides"
            class="video-thumb"
          />
          <div class="video-play">
            <div class="video-play-triangle"></div>
          </div>
          <div class="video-label">
            <span>experiencia de aprendizaje</span>
            <span class="video-label-link">▸ MÁS VÍDEOS</span>
          </div>
        </a>
      </div>

      <!-- Texto derecha -->
      <div class="dosmundos-texto">
        <h2 class="dosmundos-titulo">
          Lo mejor de los<br /><strong>dos mundos</strong>
        </h2>
        <p class="dosmundos-parrafo">
          En .h, estarás constantemente inmerso en un ecosistema digital de aprendizaje activo y
          colaborativo. Más que un observador, serás parte de una comunidad dinámica de aprendizaje
          con miembros de distintas partes del mundo.
        </p>
      </div>

    </div>

    <!-- Fila inferior: 5 columnas de features -->
    <div class="dosmundos-features">
      {features.map((f, i) => (
        <div class="feature-col">
          {i > 0 && <div class="feature-divider" />}
          <div class="feature-content">
            <h3 class="feature-titulo">{f.titulo}</h3>
            <p class="feature-texto">{f.texto}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Botón -->
    <div class="dosmundos-boton-wrap">
      <a href="#folleto" class="dosmundos-boton">QUIERO DESCARGAR EL FOLLETO</a>
    </div>

  </div>
</section>

<style>
  .dosmundos-section {
    width: 100%;
    background: #fff;
    padding: clamp(60px, 6vw, 100px) 0;
  }

  /* Hereda section-inner global — solo añadimos flex column y gap */
  .dosmundos-inner {
    display: flex;
    flex-direction: column;
    gap: clamp(48px, 5vw, 80px);
  }

  /* ── Fila superior ── */
  .dosmundos-top {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: clamp(24px, 3.5vw, 64px);
    align-items: center;
  }

  /* ── Video ── */
  .dosmundos-video {
    width: 100%;
  }

  .video-link {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 34.5px;
    overflow: hidden;
    aspect-ratio: 665 / 373;
    text-decoration: none;
  }

  .video-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .video-link:hover .video-thumb { transform: scale(1.03); }

  .video-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-play-triangle {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 28px 0 28px 52px;
    border-color: transparent transparent transparent rgba(255,255,255,0.75);
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.25));
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .video-link:hover .video-play-triangle {
    border-color: transparent transparent transparent rgba(255,255,255,0.95);
    transform: scale(1.1);
  }

  .video-label {
    position: absolute;
    bottom: 16px;
    left: 20px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .video-label span {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 300;
    font-size: 11px;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
    line-height: 1.3;
  }

  .video-label-link {
    font-weight: 500 !important;
    font-size: 10px !important;
    letter-spacing: 0.05em;
  }

  /* ── Texto derecha: más grande ── */
  .dosmundos-texto {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 2.5vw, 40px);
  }

  .dosmundos-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: clamp(36px, 45px, 70px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    margin: 0;
  }

  .dosmundos-titulo strong { font-weight: 700; }

  .dosmundos-parrafo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(16px, 38px, 28px);
    line-height: 1.6;
    color: #1a1a1a;
    margin: 0;
  }

  /* ── Features: títulos y textos más grandes ── */
  .dosmundos-features {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin-right: 10px;
  }

  .feature-col {
    display: flex;
    align-items: flex-start;
    flex: 1;
  }

  .feature-divider {
    width: 1px;
    min-height: 120px;
    background: #e0e0e0;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .feature-content {
    padding: 0 clamp(16px, 2vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-right:10px ;
  }

  .feature-col:first-child .feature-content { padding-left: 0; margin-right: ;}

  .feature-titulo {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 700;
    font-size: clamp(15px, 1.25vw, 24px);
    line-height: 1.3;
    color: #FFCD00;
    margin: 0;
  }

  .feature-texto {
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 400;
    font-size: clamp(13px, 18px, 19px);
    line-height: 1.55;
    color: #1a1a1a;
    margin: 0;
    margin-right: 50px;
  }

  /* ── Botón ── */
  .dosmundos-boton-wrap {
    display: flex;
    justify-content: center;
  }

  .dosmundos-boton {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 32px;
    border-radius: 999px;
    background: rgba(26, 26, 26, 0.88);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.10),
      inset 0 -1px 0 rgba(0,0,0,0.18),
      0 4px 16px rgba(0,0,0,0.18);
    color: #fff;
    font-family: "Noto Sans HK", sans-serif;
    font-weight: 500;
    font-size: 13.3px;
    letter-spacing: 0.08em;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.25s ease, box-shadow 0.25s ease;
  }

  .dosmundos-boton:hover {
    background: #1a1a1a;
    box-shadow: 0 6px 20px rgba(0,0,0,0.28);
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .dosmundos-inner { gap: 36px; }

    .dosmundos-top {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .dosmundos-texto { order: 1; }
    .dosmundos-video { order: 2; }

    .dosmundos-titulo { font-size: 32px; line-height: 38px; }
    .dosmundos-parrafo { font-size: 15px; line-height: 26px; }

    .video-link { border-radius: 20px; }

    .dosmundos-features {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px 20px;
    }

    .feature-col { flex: unset; border-left: 1px solid #e0e0e0; padding-left: 16px; }
    .feature-divider { display: none; }
    .feature-content { padding: 0; }
    .feature-titulo { font-size: 15px; }
    .feature-texto  { font-size: 13px; line-height: 1.6; }

    .dosmundos-boton { width: 100%; max-width: 100%; }
  }
</style>