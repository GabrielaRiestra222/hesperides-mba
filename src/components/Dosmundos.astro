---
// DosMundos.astro — Sección "Lo mejor de los dos mundos"
import videoPortada from '../img/Screenshot 2026-02-27 at 22.05.43.png';

const features = [
  { titulo: "Clases sincrónicas", texto: "Clases colaborativas y en directo." },
  { titulo: "Clases asincrónicas", texto: "Sesiones guiadas con vídeos pregrabados." },
  { titulo: "Tutorías", texto: "Videoconferencias en tiempo real para resolver dudas." },
  { titulo: "Evaluación virtual", texto: "Exámenes online." },
  { titulo: "Campus interactivo", texto: "Interactúa de manera virtual con tus profesores y compañeros en el metaverso." },
];
---

<section class="dosmundos-section">
  <div class="dosmundos-inner">

    <!-- Fila superior -->
    <div class="dosmundos-top">

      <!-- Video -->
      <div class="dosmundos-video">
        <a
          href="https://youtu.be/0ZyIsN9-sHg"
          target="_blank"
          rel="noopener noreferrer"
          class="video-link"
        >
          <img
            src={videoPortada.src}
            alt="Lo mejor de los dos mundos — Universidad de las Hespérides"
            class="video-thumb"
          />

          <div class="video-play">
            <div class="video-play-triangle"></div>
          </div>

          <div class="video-label">
            <span>experiencia de aprendizaje</span>
            <span class="video-label-link">▸ MÁS VÍDEOS</span>
          </div>
        </a>
      </div>

      <!-- Texto -->
      <div class="dosmundos-texto">
        <h2 class="dosmundos-titulo">
          Lo mejor de los<br /><strong>dos mundos</strong>
        </h2>

        <p class="dosmundos-parrafo">
          En .h, estarás constantemente inmerso en un ecosistema digital de aprendizaje activo y
          colaborativo. Más que un observador, serás parte de una comunidad dinámica de aprendizaje
          con miembros de distintas partes del mundo.
        </p>
      </div>

    </div>

    <!-- Features -->
    <div class="dosmundos-features">
      {features.map((f) => (
        <div class="feature-col">
          <div class="feature-content">
            <h3 class="feature-titulo">{f.titulo}</h3>
            <p class="feature-texto">{f.texto}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Botón -->
    <div class="dosmundos-boton-wrap">
      <a href="#" class="dosmundos-boton open-modal-cta">
        QUIERO DESCARGAR EL FOLLETO
      </a>
    </div>

  </div>
</section>

<style>

.dosmundos-section{
  width:100%;
  background:#fff;
  padding:clamp(60px,6vw,100px) 0;
}

.dosmundos-inner{
  max-width:1280px;
  margin:0 auto;
  padding:0 clamp(24px,4vw,80px);
  display:flex;
  flex-direction:column;
  gap:clamp(48px,5vw,80px);
}

.dosmundos-top{
  display:grid;
  grid-template-columns:60fr 40fr;
  gap:clamp(24px,3vw,60px);
  align-items:center;
}

.dosmundos-video{
  width:100%;
}

.video-link{
  position:relative;
  display:block;
  width:100%;
  border-radius:34px;
  overflow:hidden;
  aspect-ratio:665/373;
}

.video-thumb{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.video-play{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
}

.video-play-triangle{
  width:0;
  height:0;
  border-style:solid;
  border-width:28px 0 28px 52px;
  border-color:transparent transparent transparent rgba(255,255,255,0.8);
}

.video-label{
  position:absolute;
  bottom:16px;
  left:20px;
  display:flex;
  flex-direction:column;
}

.video-label span{
  font-size:11px;
  color:#fff;
}

.video-label-link{
  font-weight:500;
}

.dosmundos-texto{
  display:flex;
  flex-direction:column;
  gap:clamp(18px,2vw,30px);
}

.dosmundos-titulo{
  font-family:"Noto Sans HK",sans-serif;
  font-weight:600;
  font-size:clamp(36px,3.5vw,64px);
  line-height:1.1;
}

.dosmundos-parrafo{
  font-family:"Noto Sans HK",sans-serif;
  font-size:clamp(16px,1.4vw,26px);
  line-height:1.6;
}

.dosmundos-features{
  display:flex;
  max-width:1180px;
  margin:0 auto;
}

.feature-col{
  flex:1;
  position:relative;
}

.feature-col::after{
  content:"";
  position:absolute;
  right:0;
  top:6px;
  bottom:6px;
  width:1px;
  background:#393939;
}

.feature-col:last-child::after{
  display:none;
}

.feature-content{
  padding:0 clamp(12px,1vw,18px);
}

.feature-titulo{
  font-family:"Noto Sans HK",sans-serif;
  font-weight:700;
  font-size:clamp(16px,1.1vw,22px);
  color:#FFCD00;
  margin-bottom:6px;
}

.feature-texto{
  font-family:"Noto Sans HK",sans-serif;
  font-size:clamp(13px,0.9vw,18px);
  line-height:1.4;
}

.dosmundos-boton-wrap{
  display:flex;
  justify-content:center;
}

.dosmundos-boton{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:10px 30px;
  border-radius:999px;
  background:#1a1a1a;
  color:#fff;
  text-decoration:none;
  font-size:13px;
  letter-spacing:.08em;
}

.dosmundos-boton:hover{
  background:#fecc6c;
}

@media (max-width:900px){

  .dosmundos-top{
    grid-template-columns:1fr;
  }

  .dosmundos-features{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:24px;
  }

  .feature-col::after{
    display:none;
  }

}
@media (min-width: 901px){

  .dosmundos-inner{
    padding-left:200px;
    padding-right:200px;
     .dosmundos-titulo{
    font-size:clamp(28px,2.4vw,42px);
    line-height:1.15;
  }

  /* bajar subtítulo */
  .dosmundos-parrafo{
    font-size:clamp(14px,1.1vw,18px);
    line-height:1.6;
    max-width:520px;
  }

  feature-content{
  padding:0 clamp(12px,1vw,18px);
  display:flex;
  flex-direction:column;
  gap:10px;
  }

  .feature-titulo{
  font-family:"Noto Sans HK",sans-serif;
  font-weight:700;
  font-size:clamp(16px,1.1vw,22px);
  color:#FFCD00;
  min-height:2.4em;
}


  }

}

</style>